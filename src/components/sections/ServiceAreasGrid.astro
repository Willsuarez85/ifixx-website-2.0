---

<section class="section bg-neutral-50">
  <div class="container">
    <div class="text-center max-w-2xl mx-auto mb-12">
      <h2 class="text-3xl lg:text-4xl font-heading font-bold text-neutral-900 mb-4">
        Handyman Service Areas — Charlotte Metro
      </h2>
      <p class="text-lg text-neutral-600">
        iFIXX provides same-day handyman services across Charlotte and surrounding communities.
        Family-owned. Fully insured. We know these neighborhoods.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">
      {areas.map((area) => (
        <div class="bg-white rounded-xl border border-neutral-200 p-6 hover:border-primary-400 transition-colors">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">{area.icon}</span>
            <h3 class="text-lg font-heading font-bold text-neutral-900">
              <a href={`/service-areas/${area.slug}`} class="hover:text-primary-600 transition-colors">
                {area.name}
              </a>
            </h3>
          </div>
          <p class="text-sm text-neutral-600 mb-4">{area.neighborhoods}</p>
          <ul class="space-y-1.5">
            {area.popular.map((svc) => (
              <li>
                <a
                  href={`/${area.slug}/${svc.slug}`}
                  class="text-sm text-primary-600 hover:text-primary-700 hover:underline inline-flex items-center gap-1"
                >
                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
                  </svg>
                  {svc.label} in {area.name.split(",")[0]}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom paragraph — keyword rich for SEO -->
    <div class="max-w-3xl mx-auto text-center">
      <p class="text-neutral-600 leading-relaxed">
        As Charlotte's trusted handyman service, iFIXX covers the full metro area —
        from <strong>Uptown Charlotte</strong> to <strong>Ballantyne</strong>, from <strong>Matthews</strong> to <strong>Rock Hill</strong>.
        Whether you need same-day drywall repair in Dilworth, outlet replacement in Myers Park,
        ceiling fan installation in Ballantyne, or a full bathroom remodel in Pineville —
        we're your local handyman in Charlotte, NC.
        Call or text <a href="tel:+19803916833" class="text-primary-600 font-semibold hover:underline">(980) 391-6833</a> for a free estimate.
      </p>
    </div>
  </div>
</section>
