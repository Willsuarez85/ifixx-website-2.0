---
// Mobile-only sticky call bar for high-intent service/landing pages (CRO 2026-07).
// Appears after the user scrolls past the hero so it never covers the hero form.
// Uses a plain tel: anchor so BaseLayout's global click-to-call tracking picks it up.
interface Props {
  phone?: string;
  phoneDisplay?: string;
  label?: string;
}

const {
  phone = '+19803916833',
  phoneDisplay = '(980) 391-6833',
  label = 'Free Estimate',
} = Astro.props;
---

<div
  id="sticky-call-bar"
  class="fixed bottom-0 inset-x-0 z-50 lg:hidden translate-y-full transition-transform duration-300 will-change-transform"
  aria-hidden="true"
>
  <div class="bg-neutral-900/95 backdrop-blur border-t border-neutral-700 px-4 py-3 pb-[calc(0.75rem+env(safe-area-inset-bottom))]">
    <div class="flex items-center gap-3">
      <div class="flex-1 min-w-0">
        <p class="text-primary-400 text-xs font-semibold uppercase tracking-wide">{label}</p>
        <p class="text-white text-sm font-medium truncate">Talk to the owners today</p>
      </div>
      <a
        href={`tel:${phone}`}
        class="flex-shrink-0 inline-flex items-center gap-2 bg-primary-500 text-neutral-900 font-bold px-5 py-3 rounded-lg active:scale-95 transition-transform"
      >
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        Call {phoneDisplay}
      </a>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var bar = document.getElementById('sticky-call-bar');
    if (!bar) return;
    var shown = false;
    function onScroll() {
      var shouldShow = window.scrollY > 500;
      if (shouldShow !== shown) {
        shown = shouldShow;
        bar.classList.toggle('translate-y-full', !shouldShow);
        bar.setAttribute('aria-hidden', String(!shouldShow));
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  })();
</script>
