---
import LandingLayout from '../../layouts/LandingLayout.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ServiceForm from '../../components/forms/ServiceForm.astro';
import CTASection from '../../components/sections/CTASection.astro';
import CTAIntermediate from '../../components/sections/CTAIntermediate.astro';
import ScrollGallery from '../../components/sections/ScrollGallery.astro';
import GoogleReviews from '../../components/sections/GoogleReviews.astro';
import { Image } from 'astro:assets';

import heroImg from '../../assets/images/pressure-washing/v3/pw-07-v3.png';
import imgDriveway from '../../assets/images/pressure-washing/v3/pw-01-v3.png';
import imgSiding from '../../assets/images/pressure-washing/v3/pw-02-v3.png';
import imgDeck from '../../assets/images/pressure-washing/v3/pw-05-v3.png';
import imgFence from '../../assets/images/pressure-washing/v3/pw-06-v3.png';
import imgFurniture from '../../assets/images/pressure-washing/v3/pw-08-v3.png';
import imgGarage from '../../assets/images/pressure-washing/v3/pw-04-v3.png';

const serviceCards = [
  { title: 'Driveway & Walkway', subtitle: 'Concrete · Pavers · Sidewalks', body: 'Oil stains, mildew, dirt buildup, leaf marks. We bring back your concrete to the day it was poured. Most driveways finished in 60-90 minutes.', price: '$149', img: imgDriveway, alt: 'Pressure washing driveway before and after in Charlotte NC' },
  { title: 'House Siding', subtitle: 'Vinyl · Brick · Stucco', body: "Soft-wash safe for vinyl and painted surfaces. Removes algae, mildew, pollen, and Charlotte's red clay dust without damaging your home's exterior.", price: '$249', img: imgSiding, alt: 'Pressure washing house siding before and after in Charlotte NC' },
  { title: 'Deck & Patio', subtitle: 'Wood · Composite · Concrete', body: 'Strip away years of weather staining and prep wood decks for sealing or staining. We adjust pressure to protect softer woods.', price: '$199', img: imgDeck, alt: 'Pressure washing deck before and after in Charlotte NC' },
  { title: 'Fence Cleaning', subtitle: 'Wood · Vinyl · Aluminum', body: 'Remove green algae and graying from wood fences. Vinyl fences come back to white in one pass. Bundle with deck or driveway for savings.', price: '$179', img: imgFence, alt: 'Pressure washing fence before and after in Charlotte NC' },
  { title: 'Furniture & Grill', subtitle: 'Patio sets · BBQ areas', body: 'Get your outdoor entertaining space ready for guests. Patio furniture, grills, outdoor kitchens — all professionally cleaned.', price: '$99', img: imgFurniture, alt: 'Pressure washing patio furniture in Charlotte NC' },
  { title: 'Garage Floor', subtitle: 'Oil & grease removal', body: 'Years of oil drips, tire marks, and dirt removed in one visit. Optional sealing available to keep it looking new longer.', price: '$129', img: imgGarage, alt: 'Pressure washing garage floor in Charlotte NC' },
];

const pricingRows = [
  { service: 'Driveway (1-car)', startAt: '$149', range: '$149 – $249' },
  { service: 'Driveway (2-car)', startAt: '$199', range: '$199 – $349' },
  { service: 'House siding (1-story)', startAt: '$249', range: '$249 – $449' },
  { service: 'House siding (2-story)', startAt: '$399', range: '$399 – $649' },
  { service: 'Wood deck', startAt: '$199', range: '$199 – $399' },
  { service: 'Patio (concrete)', startAt: '$149', range: '$149 – $299' },
  { service: 'Wood fence (per 100ft)', startAt: '$179', range: '$179 – $299' },
  { service: 'Whole house package', startAt: '$549', range: '$549 – $949', bold: true },
];

const processSteps = [
  { num: '01', title: 'Free Estimate (5 min)', body: 'Call us or fill the form. We give you a real price over the phone — no on-site visit required for most jobs. Same-day quotes 7 days a week.' },
  { num: '02', title: 'We Schedule You In', body: 'Most jobs scheduled within 48 hours. Same-day available for emergencies (party tomorrow, photographer coming, listing your home). Just ask.' },
  { num: '03', title: 'Done in Hours, Not Days', body: 'Most pressure washing jobs are finished in a single visit. We clean up after ourselves and don\'t leave until you\'re satisfied. Pay only when the work is done right.' },
];

const faqs = [
  { q: 'How much does pressure washing cost in Charlotte?', a: 'Most residential pressure washing jobs in Charlotte run between $149 and $649 depending on the surface and size. A typical 1-car driveway is $149-249, a 1-story house siding is $249-449, and a wood deck is $199-399. We give you a real quote over the phone in 5 minutes — call (980) 391-6833.' },
  { q: 'Do you bring your own water and equipment?', a: 'Yes — iFIXX brings everything: commercial pressure washer, soft-wash chemicals (when needed), and a water tank for properties without easy outdoor spigot access. You don\'t need to provide anything except access to the area being cleaned.' },
  { q: 'Will pressure washing damage my siding or deck?', a: 'Not when done right. We use soft-wash techniques on vinyl, painted wood, and stucco surfaces (low pressure + cleaning solution that does the work, not raw PSI). For hard surfaces like concrete and brick, we use higher pressure safely. Our team has been pressure washing Charlotte homes since 2019 — we know what each surface can handle.' },
  { q: 'Can you pressure wash my house if I have a busy schedule?', a: "Yes. Most pressure washing jobs don't require you to be home. Just leave your outdoor spigot accessible, secure pets indoors, and we'll handle the rest. We text you a \"starting\" photo when we arrive and a \"done\" photo when we leave. Payment can be done over the phone or by check left at the door." },
  { q: 'How soon can you come out?', a: 'Most jobs scheduled within 48 hours. Same-day service available for emergencies (event, photoshoot, real estate listing). Just call (980) 391-6833 and tell us your timeline — Jaime or Hamed will work with you.' },
];

// TODO: Replace with real iFIXX customer reviews from Google Business Profile before publishing
const reviews = [
  { text: "Called Jaime on a Tuesday and our driveway was spotless by Thursday. Took oil stains out that I thought were permanent. Will use them for all our exterior cleaning from now on.", name: 'Sarah M.', location: 'Ballantyne' },
  { text: "We were getting ready to list our house and the siding looked terrible. iFIXX came out same-week, washed the entire exterior, and our home looked like new in the listing photos. Worth every penny.", name: 'David L.', location: 'Plaza Midwood' },
  { text: "Honest pricing, showed up on time, and didn't try to upsell me on stuff I didn't need. The deck looks like new wood again. Only handyman company in Charlotte I trust.", name: 'Maria R.', location: 'Mint Hill' },
];

const serviceSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Pressure Washing",
  "provider": {
    "@type": "LocalBusiness",
    "name": "iFIXX Remodeling & Handyman",
    "telephone": "+1-980-391-6833",
    "address": { "@type": "PostalAddress", "addressLocality": "Charlotte", "addressRegion": "NC", "addressCountry": "US" },
    "url": "https://ifixxnc.com",
    "priceRange": "$$",
    "areaServed": { "@type": "City", "name": "Charlotte" }
  },
  "areaServed": { "@type": "City", "name": "Charlotte, NC" },
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "price": "149",
    "priceSpecification": { "@type": "PriceSpecification", "minPrice": "149", "maxPrice": "949", "priceCurrency": "USD" }
  },
  "name": "Pressure Washing Charlotte NC",
  "description": "Driveway, house siding, deck, patio, and fence pressure washing in Charlotte NC. Family-owned handyman team. Same-day service available. Starting at $149.",
  "url": "https://ifixxnc.com/services/pressure-washing"
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
});
---

<LandingLayout
  title="Pressure Washing Charlotte NC | Same-Day Service from $149 | iFIXX"
  description="Charlotte's family-owned handyman team — pressure washing for driveways, decks, siding, patios, and fences. Same-day available. Free estimate. Call (980) 391-6833."
  ogImage="/images/services/pressure-washing-hero.webp"
  canonical="/services/pressure-washing"
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={serviceSchema} />
    <script type="application/ld+json" set:html={faqSchema} />
  </Fragment>

  <!-- HERO -->
  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <Image
        src={heroImg}
        alt="Professional pressure washing service in Charlotte NC — golden hour brick house cleaning by iFIXX"
        class="w-full h-full object-cover"
        widths={[640, 1024, 1920]}
        sizes="100vw"
        loading="eager"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/80 to-neutral-900/40"></div>
    </div>

    <div class="container relative z-10">
      <div class="py-16 md:py-20 lg:py-28">
        <div class="max-w-3xl">
          <!-- Badge -->
          <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-neutral-800 border border-neutral-700 mb-6">
            <span class="font-bold text-sm tracking-wide uppercase text-white">CHARLOTTE NC · INSURED · FAMILY-OWNED</span>
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold text-white mb-6 leading-tight">
            Charlotte's Same-Day<br />
            <span class="text-primary-500">Pressure Washing</span>
          </h1>

          <p class="text-lg md:text-xl text-neutral-200 mb-8 max-w-xl">
            Driveways, decks, siding, patios & fences cleaned by Charlotte's family-owned handyman team. Free estimate. Same-day available.
          </p>

          <!-- Same-Day Badge (red urgency accent) -->
          <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-red-600 text-white text-sm font-bold mb-8">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            Same-Day Available
          </div>

          <!-- CTAs -->
          <div class="flex flex-col sm:flex-row gap-4">
            <a href="tel:+19803916833" class="btn btn-primary text-lg px-8 py-4">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Call Now · (980) 391-6833
            </a>
            <a href="#estimate-form" class="btn btn-secondary text-lg px-8 py-4">
              Get Free Estimate
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="py-6 bg-neutral-100 border-y border-neutral-200">
    <div class="container">
      <div class="flex flex-wrap justify-center items-center gap-8 md:gap-12">
        <div class="flex items-center gap-2">
          <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="text-sm font-semibold text-neutral-900">Fully Insured</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-6 h-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          <span class="text-sm font-semibold text-neutral-900">Family-Owned</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-6 h-6 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span class="text-sm font-semibold text-neutral-900">Same-Day Available</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-6 h-6 text-yellow-500" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
          <span class="text-sm font-semibold text-neutral-900">5★ Local Reviews</span>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="section">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">
          What We Pressure Wash in Charlotte
        </h2>
        <p class="text-neutral-600">
          One team, one phone call, all your exterior cleaning needs handled in a single visit.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {serviceCards.map((card) => (
          <div class="bg-white rounded-xl overflow-hidden shadow-sm border border-neutral-100 hover:shadow-lg transition-shadow">
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={card.img}
                alt={card.alt}
                widths={[400, 600]}
                sizes="(max-width: 768px) 100vw, (max-width: 1024px) 50vw, 33vw"
                class="w-full h-full object-cover"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="p-6">
              <h3 class="text-lg font-heading font-bold text-neutral-900 mb-1">{card.title}</h3>
              <p class="text-xs text-neutral-500 mb-2">{card.subtitle}</p>
              <p class="text-sm text-neutral-600 mb-4">{card.body}</p>
              <p class="text-primary-600 font-heading font-bold">Starting at {card.price}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRICING TRANSPARENCY -->
  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">
            Honest Pricing — No Surprises
          </h2>
          <p class="text-neutral-600">
            Most pressure washing companies hide their prices and quote you on the spot. We don't. iFIXX gives you a real estimate before we show up, and the price you're quoted is the price you pay. Here's what most jobs run in Charlotte:
          </p>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-neutral-200 overflow-hidden">
          <table class="w-full text-left">
            <thead>
              <tr class="bg-neutral-50 border-b border-neutral-200">
                <th class="px-6 py-4 text-sm font-semibold text-neutral-900">Service</th>
                <th class="px-6 py-4 text-sm font-semibold text-neutral-900">Starting At</th>
                <th class="px-6 py-4 text-sm font-semibold text-neutral-900 hidden sm:table-cell">Typical Range</th>
              </tr>
            </thead>
            <tbody>
              {pricingRows.map((row) => (
                <tr class={`border-b border-neutral-100 ${row.bold ? 'bg-primary-50' : ''}`}>
                  <td class={`px-6 py-4 text-sm ${row.bold ? 'font-bold text-neutral-900' : 'text-neutral-700'}`}>{row.service}</td>
                  <td class={`px-6 py-4 text-sm ${row.bold ? 'font-bold text-primary-600' : 'text-primary-600 font-medium'}`}>{row.startAt}</td>
                  <td class={`px-6 py-4 text-sm text-neutral-600 hidden sm:table-cell ${row.bold ? 'font-bold' : ''}`}>{row.range}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <p class="text-xs text-neutral-500 mt-4 text-center">
          Prices vary by square footage, condition, and access. Final quote provided before work begins. We never start a job without your written approval.
        </p>

        <div class="text-center mt-6">
          <a href="tel:+19803916833" class="inline-flex items-center gap-2 text-primary-600 font-bold hover:text-primary-700">
            Call (980) 391-6833 for a free quote in 5 minutes
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">
          How It Works
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {processSteps.map((step, index) => (
          <div class="text-center relative">
            {index < processSteps.length - 1 && (
              <div class="hidden md:block absolute top-8 left-1/2 w-full h-0.5 bg-primary-200"></div>
            )}
            <div class="relative">
              <div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center shadow-lg">
                <span class="text-2xl font-heading font-bold text-neutral-900">{step.num}</span>
              </div>
            </div>
            <h3 class="text-lg font-heading font-semibold text-neutral-900 mb-2">{step.title}</h3>
            <p class="text-neutral-600 text-sm">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BEFORE/AFTER GALLERY -->
  <ScrollGallery serviceSlug="pressure-washing" title="Real Charlotte Jobs" />

  <!-- WHY iFIXX -->
  <section class="section section-alt">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">
            Why Choose a Handyman Team Over a Pressure Washing Specialist?
          </h2>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- Specialists column -->
          <div class="bg-white rounded-2xl p-6 border border-neutral-200">
            <h3 class="font-heading font-bold text-neutral-900 mb-4 text-center">Pressure Washing Specialists</h3>
            <ul class="space-y-3 text-sm text-neutral-600">
              <li class="flex items-start gap-2"><span class="text-red-500 flex-shrink-0">✗</span> Only do pressure washing — separate calls for other repairs</li>
              <li class="flex items-start gap-2"><span class="text-red-500 flex-shrink-0">✗</span> Phone tree, voicemail, "we'll get back to you"</li>
              <li class="flex items-start gap-2"><span class="text-red-500 flex-shrink-0">✗</span> Premium pricing for one-time service</li>
              <li class="flex items-start gap-2"><span class="text-red-500 flex-shrink-0">✗</span> Take your driveway and disappear</li>
              <li class="flex items-start gap-2"><span class="text-red-500 flex-shrink-0">✗</span> Generic 2-week scheduling</li>
            </ul>
          </div>

          <!-- iFIXX column -->
          <div class="bg-primary-50 rounded-2xl p-6 border-2 border-primary-500">
            <h3 class="font-heading font-bold text-neutral-900 mb-4 text-center">iFIXX Handyman Team</h3>
            <ul class="space-y-3 text-sm text-neutral-700">
              <li class="flex items-start gap-2"><span class="text-green-600 font-bold flex-shrink-0">✓</span> Pressure wash + handle any other repair on the same visit</li>
              <li class="flex items-start gap-2"><span class="text-green-600 font-bold flex-shrink-0">✓</span> Owners (Jaime & Hamed) personally answer the phone</li>
              <li class="flex items-start gap-2"><span class="text-green-600 font-bold flex-shrink-0">✓</span> Handyman pricing — typically $50-150 less per job</li>
              <li class="flex items-start gap-2"><span class="text-green-600 font-bold flex-shrink-0">✓</span> Local Charlotte family business — we'll be here next year</li>
              <li class="flex items-start gap-2"><span class="text-green-600 font-bold flex-shrink-0">✓</span> Same-day available for real emergencies</li>
            </ul>
          </div>
        </div>

        <p class="text-neutral-600 text-center mt-8 max-w-2xl mx-auto">
          iFIXX has been serving Charlotte families since 2019. Pressure washing is one of 12+ services we offer — which means when you book us once, you have a trusted local team for every future home repair.
        </p>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="section">
    <div class="container">
      <div class="text-center max-w-2xl mx-auto mb-12">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">
          What Charlotte Homeowners Are Saying
        </h2>
      </div>

      <!-- TODO: Replace with real iFIXX customer reviews from Google Business Profile -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {reviews.map((review) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-neutral-100">
            <div class="flex mb-3">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <p class="text-neutral-600 text-sm leading-relaxed mb-4">"{review.text}"</p>
            <p class="font-semibold text-neutral-900 text-sm">— {review.name}, <span class="text-neutral-500 font-normal">{review.location}</span></p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ ACCORDION -->
  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">
          Pressure Washing FAQ
        </h2>

        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <details class="group bg-white rounded-xl shadow-sm border border-neutral-100" open={index === 0}>
              <summary class="flex items-center justify-between cursor-pointer list-none p-6">
                <span class="font-semibold text-neutral-900 pr-4">{faq.q}</span>
