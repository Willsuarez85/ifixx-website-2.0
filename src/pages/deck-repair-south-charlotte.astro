---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import GoogleReviews from '../components/sections/GoogleReviews.astro';
import CTASection from '../components/sections/CTASection.astro';
import LandingEstimateForm from '../components/forms/LandingEstimateForm.astro';

const title = 'Deck Repair & Rebuilds in South Charlotte | Boards, Railings, Steps | iFIXX';
const description = 'Deck repair and rebuilds in South Charlotte, Ballantyne, Waxhaw, Indian Land, and Fort Mill. Rotten boards, loose railings, broken steps, soft spots, wood rot. Repair first, with rebuild options when the deck needs more than a small fix. Insured local crew from iFIXX.';
const canonical = '/deck-repair-south-charlotte';
const heroImage = '/images/projects/deck-wood-exterior-patio.webp';
const supportImage = '/images/projects/outdoor-living-raised-deck-railing-construction.webp';
const leadType = 'deck_repair';

const serviceAreas = ['South Charlotte', 'Ballantyne', 'Waxhaw', 'Indian Land', 'Fort Mill', 'Pineville', 'Matthews', 'Weddington'];

const repairItems = [
  'Rotten, soft, cracked, or damaged deck boards',
  'Loose railings, shaky posts, and handrail repairs',
  'Broken steps, stair treads, and landing repairs',
  'Wood rot and framing or joist concerns that need review',
  'Staining, sealing, and finish work after the repair',
  'Repair first when it makes sense, and a full rebuild when the deck is past saving',
  'Punch-list deck repairs before selling, renting, or entertaining'
];

const galleryImages = [
  { src: '/images/projects/carpentry-stair-repair-technician-drilling-wood.webp', alt: 'iFIXX technician repairing wood deck stairs and steps' },
  { src: '/images/projects/deck-wood-exterior-patio.webp', alt: 'Repaired wood deck boards and exterior patio' },
  { src: '/images/projects/outdoor-living-raised-deck-railing-construction.webp', alt: 'Deck railing, posts, and handrail repair' },
  { src: '/images/projects/pressure-washing-deck-before-after.webp', alt: 'Deck cleaning and finish refresh, before and after' },
  { src: '/images/projects/deck-wood-railing-south-charlotte.webp', alt: 'Wood deck with rebuilt railing by iFIXX in South Charlotte' },
  { src: '/images/projects/deck-porch-framing-south-charlotte.webp', alt: 'Structural deck and porch framing during a rebuild in South Charlotte' },
  { src: '/images/projects/deck-porch-framing-crew-south-charlotte.webp', alt: 'iFIXX crew rebuilding a deck and porch structure in South Charlotte' },
  { src: '/images/projects/deck-covered-porch-south-charlotte.webp', alt: 'Finished deck rebuild with covered porch by iFIXX in South Charlotte' }
];

const whoBullets = [
  'A local, family-owned company. Repairing and building decks is what we do.',
  'Over ten years of hands-on experience with decks, rebuilds, and screened porches.',
  'Repair-first: we fix what can be fixed and tell you straight when it is past saving.',
  'Clear, honest pricing up front, with a free online estimate to start.',
  'We show up, we finish the job, and we do not disappear halfway through.',
  'Insured, professional, and local to the Charlotte area. 85 five-star reviews.'
];

const processSteps = [
  { title: 'Start with the problem', text: 'Tell us what feels wrong: soft boards, loose rails, broken steps, rot, staining, or a deck that no longer feels trustworthy.' },
  { title: 'We look for the repair path', text: 'Many deck issues can be repaired if they are caught early. We review whether the scope looks targeted, finish-related, structural, or likely larger.' },
  { title: 'Repair before it becomes bigger', text: 'When approved, we handle the agreed repair and point out anything that should be watched before it becomes a more expensive project.' }
];

const faqs = [
  { q: 'Can a damaged deck be repaired, or does it need a rebuild?', a: 'Often it can be repaired. A few bad boards, loose rails, or broken steps do not always mean the whole deck needs to be rebuilt. The key is reviewing it early before rot, movement, or water damage spreads. When the framing or posts are genuinely past saving, we will tell you straight and scope a rebuild instead of patching something unsafe.' },
  { q: 'Can you estimate deck repair online?', a: 'Many deck repairs can start with an online estimate request. Clear photos of the boards, rails, steps, underside, and access area help us understand whether the next step can be scoped remotely or needs an in-person visit.' },
  { q: 'Do you repair deck boards, rails, and steps?', a: 'Yes. iFIXX helps South Charlotte homeowners with boards, railings, steps, small wood repairs, staining/sealing conversations, and repair-first guidance.' },
  { q: 'Are you local to South Charlotte?', a: 'Yes. iFIXX is an insured, local Charlotte-area team, not a national franchise. We regularly serve South Charlotte, Ballantyne, Waxhaw, Indian Land, Fort Mill, Pineville, Matthews, Weddington, and nearby neighborhoods.' },
  { q: 'When should I stop using my deck?', a: 'If the deck shifts, railings move, steps are loose, posts look rotten, or boards feel soft underfoot, stop using that area until it is reviewed. Safety concerns may need an in-person inspection before final pricing.' },
  { q: 'Do you build new decks, or only repair?', a: 'Both. If your home does not have a deck yet, or you want to replace an old one with something bigger, we also build new decks and outdoor living spaces. Tell us "build a new deck" in the form and we will scope the design, materials, and price with you.' }
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Deck Repair & Rebuilds in South Charlotte',
  description,
  serviceType: 'Deck repair and rebuilds',
  url: `https://ifixxnc.com${canonical}`,
  image: `https://ifixxnc.com${heroImage}`,
  provider: { '@id': 'https://ifixxnc.com/#business' },
  areaServed: serviceAreas,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ifixxnc.com/' },
    { '@type': 'ListItem', position: 2, name: 'Deck Repair South Charlotte', item: `https://ifixxnc.com${canonical}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({ '@type': 'Question', name: faq.q, acceptedAnswer: { '@type': 'Answer', text: faq.a } }))
};
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={heroImage}>
  <Fragment slot="schema"><script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} /><script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} /><script type="application/ld+json" set:html={JSON.stringify(faqSchema)} /></Fragment>

  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0"><img src={heroImage} alt="Deck repair and exterior patio work by local iFIXX team" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" /><div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/85 to-neutral-900/55"></div></div>
    <div class="container relative z-10"><div class="py-10 lg:py-16"><nav class="mb-6"><ol class="flex items-center gap-2 text-sm text-neutral-300"><li><a href="/" class="hover:text-primary-500 transition-colors">Home</a></li><li class="text-neutral-500">/</li><li class="text-white font-medium">Deck Repair South Charlotte</li></ol></nav>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
        <div class="order-1 lg:order-1">
          <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">Repair-first • Rebuild when it's worth it • Not a franchise</span>
          <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4">Deck Repair &amp; Rebuilds in South Charlotte</h1>
          <p class="text-lg text-neutral-200 mb-4 max-w-xl">Soft boards, loose rails, broken steps, or wood rot? Caught early, most of it is a focused repair, not a full replacement. And when a deck really is past saving, we'll tell you straight and scope a rebuild.</p>
          <p class="text-neutral-300 mb-6 max-w-xl">iFIXX helps South Charlotte homeowners figure out the repair-or-rebuild path: boards, rails, steps, staining, sealing, or a deeper review if the deck may be unsafe. Our local, family-owned team reviews every request personally, gives you an upfront price, and moves fast on urgent repairs.</p>
          <div class="flex flex-col sm:flex-row gap-3 mb-3"><a href="#estimate-form" class="btn btn-primary landing-primary-cta" data-lead-type={leadType}>Request a Free Online Estimate</a><a href="tel:+19803916833" class="btn btn-outline-light landing-phone-cta" data-lead-type={leadType}>Call (980) 391-6833</a></div><p class="text-sm text-neutral-300 mb-8">Want a brand new deck instead? <a href="/deck-builder-south-charlotte" class="text-primary-400 underline underline-offset-2 hover:text-primary-300">See our new deck builds</a></p>
          <div class="grid grid-cols-2 gap-4">{['Repair or rebuild', 'Boards, rails, steps', 'Wood rot & soft spots', 'Insured local crew'].map((chip) => (<div class="flex items-center gap-3 text-white"><span class="w-9 h-9 rounded-full bg-primary-500/20 flex items-center justify-center text-primary-400">✓</span><span class="text-sm font-medium">{chip}</span></div>))}</div>
        </div>
        <div id="estimate-form" class="order-2 lg:order-2 scroll-mt-24 min-w-0"><LandingEstimateForm serviceSlug="deck-repair" serviceTitle="Deck Repair & Rebuilds" formId="deck-south-charlotte-estimate" leadType="deck_repair" formName="South Charlotte Deck Repair Landing Form" issueLabel="What needs repair?" includeSafetyConcern={true} issueOptions={['rotten/soft boards', 'loose railing', 'broken steps', 'wood rot', 'staining/sealing', 'repair vs rebuild advice', 'full deck rebuild', 'build a new deck', 'other']} descriptionPlaceholder="Briefly describe what is wrong with the deck and where you are located (photos help)." photoLabel="Upload photos if you have them" submitLabel="Request a Free Online Estimate" /></div>
      </div>
    </div></div>
  </section>

  <TrustBar variant="light" />

  <section class="section"><div class="container"><div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"><div><span class="badge mb-4">The pain: the deck keeps getting worse</span><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-6">A small deck problem can become a bigger project if it sits too long</h2><p class="text-neutral-600 mb-5">Most homeowners wait because they are afraid every deck issue means “replace the whole thing.” Sometimes that is true. But often, the first smart move is a focused repair: replace boards, tighten or rebuild a rail section, fix steps, or deal with rot before it spreads.</p><p class="text-neutral-600 mb-8">We are repair-first: we tell you what can reasonably be fixed, what should be watched, and what is genuinely past repair. If the framing or posts are too far gone, we will say so and scope a rebuild instead of patching something unsafe. Your call, with an honest price either way.</p><ul class="space-y-4">{repairItems.map((item) => (<li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>))}</ul></div><div class="rounded-2xl overflow-hidden shadow-2xl"><img src={supportImage} alt="Raised deck railing and wood repair project" class="w-full aspect-[4/3] object-cover" width="700" height="525" loading="lazy" decoding="async" /></div></div></div></section>

  <section class="section section-alt"><div class="container"><div class="max-w-3xl mx-auto text-center mb-12"><span class="badge mb-4">Recent deck repair examples</span><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Boards, railings, steps, and wood-rot repairs</h2><p class="text-neutral-600">Use the gallery as a guide for the kinds of deck repairs we can discuss from photos: stair and step fixes, board replacement, railing and post work, finish refresh, and cutting out wood rot before it spreads.</p></div><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">{galleryImages.map((image) => (<figure class="group overflow-hidden rounded-2xl bg-white shadow-sm border border-neutral-200"><img src={image.src} alt={image.alt} class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-300" width="520" height="390" loading="lazy" decoding="async" /></figure>))}</div></div></section>

  <section class="section"><div class="container"><div class="max-w-3xl mx-auto text-center mb-12"><span class="badge mb-4">Simple local process</span><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Repair before it becomes a larger investment</h2><p class="text-neutral-600">You do not need to diagnose the deck yourself. Tell us what you are seeing, send photos if you have them, and our local team will help identify the next practical step.</p></div><div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">{processSteps.map((step, index) => (<div class="card p-6 text-center"><div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center font-heading font-bold text-neutral-900 text-xl">{index + 1}</div><h3 class="font-heading font-bold text-neutral-900 mb-2">{step.title}</h3><p class="text-sm text-neutral-600">{step.text}</p></div>))}</div></div></section>

  <section class="section section-alt"><div class="container"><div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto"><div class="bg-white rounded-2xl p-8 shadow-sm border border-neutral-200"><h2 class="text-2xl font-heading font-bold text-neutral-900 mb-4">Who is iFIXX?</h2><img src="/images/ui/team.webp" alt="Jaime Aguilar, owner of iFIXX, with his team" class="w-full aspect-[16/9] object-cover rounded-xl mb-4" width="640" height="360" loading="lazy" decoding="async" /><p class="text-neutral-600 mb-4">Meet Jaime Aguilar, the owner. iFIXX is not a franchise or a call center: it is a local Charlotte family company, and the person responsible for your repair is the same person who answers your call.</p><ul class="space-y-3">{whoBullets.map((item) => (<li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>))}</ul></div><div class="bg-neutral-900 rounded-2xl p-8 text-white shadow-xl"><h2 class="text-2xl font-heading font-bold mb-4">South Charlotte service areas</h2><div class="flex flex-wrap gap-2">{serviceAreas.map((area) => (<span class="px-3 py-2 rounded-full bg-white/10 text-sm">{area}</span>))}</div><p class="text-neutral-300 mt-5">If you are nearby but not listed, send the request and we will confirm availability.</p></div></div></div></section>

  <section class="section"><div class="container"><div class="max-w-4xl mx-auto rounded-2xl bg-neutral-900 text-white p-8 lg:p-10 shadow-xl"><div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 items-center"><div><span class="inline-block px-3 py-1 rounded-full bg-primary-500/20 text-primary-400 text-xs font-bold uppercase tracking-wide mb-3">No deck yet?</span><h2 class="text-2xl lg:text-3xl font-heading font-bold mb-3">We build new decks too, not just repairs</h2><p class="text-neutral-300 max-w-xl">If your home doesn't have a deck, or you're ready to replace an old one with something bigger, we build new decks and outdoor living spaces across South Charlotte. Honest pricing, insured local crew, and the owners involved from the first design conversation.</p></div><a href="/deck-builder-south-charlotte" class="btn btn-primary whitespace-nowrap">See new deck builds →</a></div></div></div></section>

  <section class="section"><div class="container"><div class="max-w-3xl mx-auto"><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">Deck Repair FAQs</h2><div class="space-y-4">{faqs.map((faq, index) => (<details class="group bg-white rounded-xl shadow-sm" open={index === 0}><summary class="flex items-center justify-between cursor-pointer list-none p-6"><span class="font-semibold text-neutral-900 pr-4">{faq.q}</span><span class="text-primary-600 group-open:rotate-180 transition-transform">⌄</span></summary><div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div></details>))}</div></div></div></section>

  <GoogleReviews title="What Charlotte Homeowners Say" />
  <CTASection headline="Repair it now, or rebuild it right. Let's figure out which." subtext="Request a free online estimate for deck boards, railings, steps, soft spots, wood rot, staining, or a full rebuild across South Charlotte, Ballantyne, Waxhaw, Indian Land, and Fort Mill." />

  <script is:inline>
    document.addEventListener('click', (event) => {
      const cta = event.target.closest('.landing-primary-cta');
      const phone = event.target.closest('.landing-phone-cta');
      if (!cta && !phone) return;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: cta ? 'landing_cta_click' : 'phone_click', lead_type: 'deck_repair', campaign_test: 'ifixx_south_charlotte_service_test_2026_07', form_location: window.location.pathname });
    });
  </script>
</BaseLayout>
