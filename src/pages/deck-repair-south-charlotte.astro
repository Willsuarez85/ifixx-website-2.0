---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import GoogleReviews from '../components/sections/GoogleReviews.astro';
import CTASection from '../components/sections/CTASection.astro';
import LandingEstimateForm from '../components/forms/LandingEstimateForm.astro';

const title = 'Deck Repair in South Charlotte | Boards, Railings, Steps | iFIXX';
const description = 'Deck repair for boards, railings, steps, soft spots, rot, staining, and safety concerns in South Charlotte. Request a deck repair estimate from iFIXX.';
const canonical = '/deck-repair-south-charlotte/';
const heroImage = '/images/projects/deck-wood-exterior-patio.webp';
const supportImage = '/images/projects/outdoor-living-raised-deck-railing-construction.webp';
const leadType = 'deck_repair';

const repairItems = [
  'Deck board replacement',
  'Rotten or soft boards',
  'Railing repair or replacement',
  'Stair and step repair',
  'Joist and framing concerns',
  'Wood rot',
  'Deck staining and sealing',
  'Repair-before-replace consults'
];

const processSteps = [
  { title: 'Send deck photos', text: 'Upload clear photos of boards, railings, steps, framing concerns, or soft spots.' },
  { title: 'We check repair path', text: 'Our team reviews whether it looks like a targeted repair, safety fix, staining/sealing, or larger scope.' },
  { title: 'Repair safely', text: 'When approved, we handle the agreed repair scope and flag anything that should not be ignored.' }
];

const faqs = [
  { q: 'Can you estimate deck repair from photos?', a: 'Many deck repairs can be scoped faster when you send clear photos of the damaged area, underside if accessible, railings, steps, and any soft or rotten boards. Safety or framing concerns may require an in-person visit before final pricing.' },
  { q: 'Do you repair deck boards and railings?', a: 'Yes. iFIXX can help with deck board replacement, loose or damaged railings, broken steps, and related wood repair needs.' },
  { q: 'Can you stain or seal after repair?', a: 'Yes. If the repair calls for staining or sealing, we can discuss that as part of the scope or as a follow-up finish step.' },
  { q: 'How do I know if my deck is unsafe?', a: 'Stop using the deck and call if boards feel soft, railings move, steps are loose, posts look rotten, or the deck shifts when walked on. Photos help us triage, but safety concerns may need an in-person inspection.' },
  { q: 'Do you serve Ballantyne and South Charlotte?', a: 'Yes. We serve South Charlotte, Ballantyne, Pineville, Matthews, and nearby Charlotte-area neighborhoods.' }
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Deck Repair in South Charlotte',
  description,
  serviceType: 'Deck repair',
  url: `https://ifixxnc.com${canonical}`,
  image: `https://ifixxnc.com${heroImage}`,
  provider: { '@id': 'https://ifixxnc.com/#business' },
  areaServed: ['South Charlotte', 'Ballantyne', 'Pineville', 'Matthews'],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ifixxnc.com/' },
    { '@type': 'ListItem', position: 2, name: 'Deck Repair South Charlotte', item: `https://ifixxnc.com${canonical}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a }
  }))
};
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={heroImage}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="Wood deck and exterior patio repair by iFIXX" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/85 to-neutral-900/55"></div>
    </div>

    <div class="container relative z-10">
      <div class="py-10 lg:py-16">
        <nav class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-neutral-300">
            <li><a href="/" class="hover:text-primary-500 transition-colors">Home</a></li>
            <li class="text-neutral-500">/</li>
            <li class="text-white font-medium">Deck Repair South Charlotte</li>
          </ol>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <div class="order-1 lg:order-1">
            <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">
              South Charlotte • Ballantyne • Pineville • Matthews
            </span>
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4">
              Deck Repair in South Charlotte
            </h1>
            <p class="text-lg text-neutral-200 mb-6 max-w-xl">
              Rotten boards, loose rails, broken steps, soft spots, or a deck that needs attention? Send photos and our local team will help you decide whether it’s a targeted repair, safety fix, or larger rebuild.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 mb-8">
              <a href="#estimate-form" class="btn btn-primary landing-primary-cta" data-lead-type={leadType}>Request a Deck Repair Estimate</a>
              <a href="tel:+19803916833" class="btn btn-outline-light landing-phone-cta" data-lead-type={leadType}>Call (980) 391-6833</a>
            </div>
            <div class="grid grid-cols-2 gap-4">
              {['Repair-first approach', 'Boards, rails, steps & staining', 'Local South Charlotte team', 'Insured'].map((chip) => (
                <div class="flex items-center gap-3 text-white">
                  <span class="w-9 h-9 rounded-full bg-primary-500/20 flex items-center justify-center text-primary-400">✓</span>
                  <span class="text-sm font-medium">{chip}</span>
                </div>
              ))}
            </div>
          </div>

          <div id="estimate-form" class="order-2 lg:order-2 scroll-mt-24 min-w-0">
            <LandingEstimateForm
              serviceSlug="deck-repair"
              serviceTitle="Deck Repair"
              formId="deck-south-charlotte-estimate"
              leadType="deck_repair"
              formName="South Charlotte Deck Repair Landing Form"
              issueOptions={['rotten/soft boards', 'loose railing', 'broken steps', 'joist/framing concern', 'staining/sealing', 'unsure/safety concern', 'other']}
              descriptionPlaceholder="Briefly describe what needs to be repaired."
              photoLabel="Upload photos of the deck issue"
              includeSafetyConcern={true}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="badge mb-4">Repair-first deck work</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-6">Deck repairs we can help with</h2>
          <p class="text-neutral-600 mb-8">Not every deck problem needs a full rebuild. iFIXX helps South Charlotte homeowners understand whether the right next step is a targeted repair, safety fix, staining/sealing, or larger scope.</p>
          <ul class="space-y-4">
            {repairItems.map((item) => (
              <li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-2xl">
          <img src={supportImage} alt="Raised deck railing and wood repair project" class="w-full aspect-[4/3] object-cover" width="700" height="525" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="badge mb-4">Repair before you replace</span>
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Start with the right repair decision</h2>
        <p class="text-neutral-600">A soft board, loose rail, or broken step may be repairable — but safety issues should not be ignored. Send photos so we can help triage the concern and recommend the next step.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {processSteps.map((step, index) => (
          <div class="card p-6 text-center">
            <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center font-heading font-bold text-neutral-900 text-xl">{index + 1}</div>
            <h3 class="font-heading font-bold text-neutral-900 mb-2">{step.title}</h3>
            <p class="text-sm text-neutral-600">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <div class="bg-neutral-900 rounded-2xl p-8 lg:p-10 text-white shadow-xl">
          <h2 class="text-2xl lg:text-3xl font-heading font-bold mb-4">Can this be estimated from photos?</h2>
          <p class="text-neutral-200 text-lg">Photos help us see the damaged boards, railings, steps, and access conditions. Some deck repairs can be scoped from photos; framing and safety concerns may need a visit before final pricing.</p>
        </div>
        <div class="bg-red-50 border border-red-200 rounded-2xl p-8 lg:p-10 shadow-xl">
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-red-900 mb-4">Safety: when to stop using the deck</h2>
          <p class="text-red-800 text-lg">If the deck feels unstable, railings move, steps are loose, posts look rotten, or boards feel soft underfoot, stop using that area until it is reviewed.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">Deck Repair FAQs</h2>
        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <details class="group bg-white rounded-xl shadow-sm" open={index === 0}>
              <summary class="flex items-center justify-between cursor-pointer list-none p-6"><span class="font-semibold text-neutral-900 pr-4">{faq.q}</span><span class="text-primary-600 group-open:rotate-180 transition-transform">⌄</span></summary>
              <div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <GoogleReviews title="What Charlotte Homeowners Say" />

  <CTASection
    headline="Ready to repair your deck?"
    subtext="Request a deck repair estimate for boards, railings, steps, soft spots, rot, staining, or safety concerns in South Charlotte."
  />

  <script is:inline>
    document.addEventListener('click', (event) => {
      const cta = event.target.closest('.landing-primary-cta');
      const phone = event.target.closest('.landing-phone-cta');
      if (!cta && !phone) return;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: cta ? 'landing_cta_click' : 'phone_click',
        lead_type: 'deck_repair',
        campaign_test: 'ifixx_south_charlotte_service_test_2026_07',
        form_location: window.location.pathname
      });
    });
  </script>
</BaseLayout>
