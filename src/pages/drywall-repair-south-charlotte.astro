---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import GoogleReviews from '../components/sections/GoogleReviews.astro';
import CTASection from '../components/sections/CTASection.astro';
import LandingEstimateForm from '../components/forms/LandingEstimateForm.astro';

const title = 'Drywall Repair in South Charlotte | Holes, Cracks, Ceilings & Water Damage | iFIXX';
const description = 'Drywall repair in South Charlotte, Ballantyne, Pineville, and Matthews: holes, cracks, nail pops, ceiling patches, water-damage drywall, and texture matching. Insured local handyman team. Request a free online estimate from iFIXX.';
const canonical = '/drywall-repair-south-charlotte';
const heroImage = '/images/services/drywall/dr-01-hole-patching-closeup.webp';
const supportImage = '/images/projects/painting-drywall-dining-room-wainscoting-chandelier.webp';
const leadType = 'drywall_repair';

const serviceAreas = ['South Charlotte', 'Ballantyne', 'Pineville', 'Matthews', 'Weddington', 'Waxhaw', 'SouthPark', 'Steele Creek'];

const repairItems = [
  'Holes from doors, furniture, accidents, or removed fixtures',
  'Cracks, nail pops, seams, and settling damage',
  'Ceiling patches and water-damaged drywall once the leak is solved',
  'Sagging, soft, or crumbling drywall that needs to be cut out and replaced',
  'Texture matching: orange peel, knockdown, smooth, and popcorn',
  'Punch-list drywall and small home repairs before selling or listing',
  'Finish blending and paint touch-up to support the patch (not the main job)'
];

const galleryImages = [
  { src: '/images/services/drywall/dr-01-hole-patching-closeup.webp', alt: 'Close-up drywall hole patching in progress' },
  { src: '/images/services/drywall/dr-02-before-after-split.webp', alt: 'Drywall repair before and after split image' },
  { src: '/images/services/drywall/dr-03-sanding-drywall.webp', alt: 'Drywall sanding and smoothing before paint' },
  { src: '/images/services/drywall/dr-04-joint-compound.webp', alt: 'Joint compound applied to drywall repair' },
  { src: '/images/services/drywall/dr-05-water-damage-beforeafter.webp', alt: 'Water damaged drywall before and after repair' },
  { src: '/images/services/drywall/dr-07-joint-compound-patching.webp', alt: 'Drywall patch with joint compound' },
  { src: '/images/services/drywall/dr-08-ceiling-water-damage-beforeafter.webp', alt: 'Ceiling drywall water damage repair before and after' },
  { src: '/images/services/drywall/dr-09-sanding-smooth.webp', alt: 'Smooth sanded drywall ready for paint' }
];

const processSteps = [
  { title: 'Tell us what happened', text: 'Send the basics: hole, crack, ceiling patch, water-damaged drywall, soft spot, or texture issue. Photos help us understand the surface faster.' },
  { title: 'We scope the repair', text: 'We look at patch size, texture, wall age, and whether the damage is surface-level or needs drywall cut out and replaced, and whether a visit is needed.' },
  { title: 'Repair, texture, and blend', text: 'When approved, our local team patches, sands, and matches the texture, then blends the finish so the repair does not leave an obvious square on your wall.' }
];

const faqs = [
  { q: 'Can you estimate drywall repair online?', a: 'Yes, many drywall repairs can start with an online estimate request. Clear photos and a short description help us understand the size, location, and texture before we recommend the next step.' },
  { q: 'What kind of drywall damage do you repair?', a: 'Holes, cracks, nail pops, seams, ceiling patches, water-damaged drywall once the leak is solved, and soft or crumbling sections that need to be cut out and replaced. We also handle small punch-list repairs around the house.' },
  { q: 'Can you match my wall or ceiling texture?', a: 'We handle common textures like orange peel, knockdown, smooth finishes, and popcorn ceiling texture. Exact matching depends on the age and condition of the surrounding surface, and we will tell you honestly what to expect.' },
  { q: 'Do you repair water-damaged drywall?', a: 'Yes, once the source of the leak or moisture has been handled. If the leak is active or there is a mold concern, that needs to be addressed before we close the wall or ceiling.' },
  { q: 'Do you also paint or touch up after the patch?', a: 'We can blend and touch up the finish so the repair does not leave an obvious square, but drywall repair is the main job here, not full repainting. On older or sun-faded walls, a perfect paint match is not always possible, so we are upfront about it before we start.' },
  { q: 'Are you a local company or a franchise?', a: 'iFIXX is an insured, local Charlotte-area team, not a national franchise call center. We work across South Charlotte, Ballantyne, Pineville, Matthews, and nearby neighborhoods.' }
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Drywall Repair in South Charlotte',
  description,
  serviceType: 'Drywall repair',
  url: `https://ifixxnc.com${canonical}`,
  image: `https://ifixxnc.com${heroImage}`,
  provider: { '@id': 'https://ifixxnc.com/#business' },
  areaServed: serviceAreas,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ifixxnc.com/' },
    { '@type': 'ListItem', position: 2, name: 'Drywall Repair South Charlotte', item: `https://ifixxnc.com${canonical}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({ '@type': 'Question', name: faq.q, acceptedAnswer: { '@type': 'Answer', text: faq.a } }))
};
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={heroImage}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="Drywall repair patching in South Charlotte by iFIXX" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/85 to-neutral-900/55"></div>
    </div>
    <div class="container relative z-10">
      <div class="py-10 lg:py-16">
        <nav class="mb-6"><ol class="flex items-center gap-2 text-sm text-neutral-300"><li><a href="/" class="hover:text-primary-500 transition-colors">Home</a></li><li class="text-neutral-500">/</li><li class="text-white font-medium">Drywall Repair South Charlotte</li></ol></nav>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <div class="order-1 lg:order-1">
            <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">Local South Charlotte team • Not a franchise</span>
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4">Drywall Repair in South Charlotte</h1>
            <p class="text-lg text-neutral-200 mb-4 max-w-xl">Holes, cracks, nail pops, ceiling patches, water-damaged drywall, soft spots. If a piece of your home needs fixing, iFIXX repairs the damage and leaves the wall looking right again. Honest, insured, local handyman work.</p>
            <p class="text-neutral-300 mb-6 max-w-xl">Request a free online estimate and our local team will review the basics, ask for photos if helpful, and recommend the right next step. Our local, family-owned team reviews every request personally and gives you an upfront price. Serving South Charlotte, Ballantyne, Pineville, Matthews, and nearby neighborhoods.</p>
            <div class="flex flex-col sm:flex-row gap-3 mb-8">
              <a href="#estimate-form" class="btn btn-primary landing-primary-cta" data-lead-type={leadType}>Request a Free Online Estimate</a>
              <a href="tel:+19803916833" class="btn btn-outline-light landing-phone-cta" data-lead-type={leadType}>Call (980) 391-6833</a>
            </div>
            <div class="grid grid-cols-2 gap-4">
              {['Holes, cracks & ceilings', 'Water-damage drywall repair', 'South Charlotte focus', 'Insured local team'].map((chip) => (
                <div class="flex items-center gap-3 text-white"><span class="w-9 h-9 rounded-full bg-primary-500/20 flex items-center justify-center text-primary-400">✓</span><span class="text-sm font-medium">{chip}</span></div>
              ))}
            </div>
          </div>
          <div id="estimate-form" class="order-2 lg:order-2 scroll-mt-24 min-w-0">
            <LandingEstimateForm serviceSlug="drywall-repair" serviceTitle="Drywall Repair" formId="drywall-south-charlotte-estimate" leadType="drywall_repair" formName="South Charlotte Drywall Repair Landing Form" issueOptions={['hole', 'crack', 'nail pops', 'ceiling damage', 'water-damaged drywall', 'soft/sagging drywall', 'texture matching', 'finish/paint touch-up', 'other']} descriptionPlaceholder="Briefly describe the drywall damage and where it is in the home (photos help)." photoLabel="Upload photos if you have them" submitLabel="Request a Free Online Estimate" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="badge mb-4">The pain: damaged drywall you keep walking past</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-6">From a hole in the wall to a water-stained ceiling, we fix the piece of your home that is bugging you</h2>
          <p class="text-neutral-600 mb-5">A doorknob hole, a settling crack, popped nails, a ceiling stain after a leak, or a soft section that needs cutting out. These are the small repairs that sit on the to-do list for months and make a room feel unfinished.</p>
          <p class="text-neutral-600 mb-8">We repair the damage first, match the texture, and then blend the finish so the patch does not leave an obvious square. Drywall repair is the job; the finish is what makes it disappear.</p>
          <ul class="space-y-4">{repairItems.map((item) => (<li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>))}</ul>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-2xl"><img src={supportImage} alt="Finished drywall and paint blending project" class="w-full aspect-[4/3] object-cover" width="700" height="525" loading="lazy" decoding="async" /></div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="badge mb-4">Recent drywall repair examples</span>
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Drywall, ceiling, texture, and finish work</h2>
        <p class="text-neutral-600">Use the gallery as a guide for the kinds of repairs we can discuss from photos: small holes, ceiling damage, joint compound, sanding, before/after patches, and water-damage repair after the source is fixed.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {galleryImages.map((image) => (<figure class="group overflow-hidden rounded-2xl bg-white shadow-sm border border-neutral-200"><img src={image.src} alt={image.alt} class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-300" width="520" height="390" loading="lazy" decoding="async" /></figure>))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12"><span class="badge mb-4">Simple local process</span><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">A clear path from damage to finished wall</h2><p class="text-neutral-600">You should not have to guess whether to call a handyman, drywall crew, or painter. Start with the online estimate and we will help scope the right repair path.</p></div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">{processSteps.map((step, index) => (<div class="card p-6 text-center"><div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center font-heading font-bold text-neutral-900 text-xl">{index + 1}</div><h3 class="font-heading font-bold text-neutral-900 mb-2">{step.title}</h3><p class="text-sm text-neutral-600">{step.text}</p></div>))}</div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-neutral-200"><h2 class="text-2xl font-heading font-bold text-neutral-900 mb-4">Who is iFIXX?</h2><p class="text-neutral-600 mb-4">iFIXX Remodeling & Handyman Services is a Charlotte-area local team serving homeowners who want clear communication, clean work, and practical repair recommendations.</p><p class="text-neutral-600">We are not a national franchise routing your request through a call center. We work locally across South Charlotte and nearby areas, and we care about whether the repair actually solves the homeowner’s problem.</p></div>
        <div class="bg-neutral-900 rounded-2xl p-8 text-white shadow-xl"><h2 class="text-2xl font-heading font-bold mb-4">South Charlotte service areas</h2><div class="flex flex-wrap gap-2">{serviceAreas.map((area) => (<span class="px-3 py-2 rounded-full bg-white/10 text-sm">{area}</span>))}</div><p class="text-neutral-300 mt-5">If you are nearby but not listed, send the request anyway and we will confirm availability.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container"><div class="max-w-3xl mx-auto"><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">Drywall Repair FAQs</h2><div class="space-y-4">{faqs.map((faq, index) => (<details class="group bg-white rounded-xl shadow-sm" open={index === 0}><summary class="flex items-center justify-between cursor-pointer list-none p-6"><span class="font-semibold text-neutral-900 pr-4">{faq.q}</span><span class="text-primary-600 group-open:rotate-180 transition-transform">⌄</span></summary><div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div></details>))}</div></div></div>
  </section>

  <GoogleReviews title="What Charlotte Homeowners Say" />
  <CTASection headline="Ready to get that drywall fixed for good?" subtext="Request a free online estimate for holes, cracks, nail pops, ceiling patches, water-damaged drywall, and texture matching in South Charlotte." />

  <script is:inline>
    document.addEventListener('click', (event) => {
      const cta = event.target.closest('.landing-primary-cta');
      const phone = event.target.closest('.landing-phone-cta');
      if (!cta && !phone) return;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: cta ? 'landing_cta_click' : 'phone_click', lead_type: 'drywall_repair', campaign_test: 'ifixx_south_charlotte_service_test_2026_07', form_location: window.location.pathname });
    });
  </script>
</BaseLayout>
