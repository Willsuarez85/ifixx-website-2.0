---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import GoogleReviews from '../components/sections/GoogleReviews.astro';
import CTASection from '../components/sections/CTASection.astro';
import LandingEstimateForm from '../components/forms/LandingEstimateForm.astro';

const title = 'Drywall Repair + Paint Matching in South Charlotte | iFIXX';
const description = 'Drywall patching, ceiling repair, texture matching, and paint touch-ups in South Charlotte. Request a photo estimate from iFIXX.';
const canonical = '/drywall-repair-south-charlotte/';
const heroImage = '/images/projects/drywall-repair-patching-hole-spackling.webp';
const supportImage = '/images/projects/painting-drywall-dining-room-wainscoting-chandelier.webp';
const leadType = 'drywall_repair';

const repairItems = [
  'Drywall holes and dents',
  'Cracks and nail pops',
  'Ceiling drywall patches',
  'Water stain/damage areas after the source is handled',
  'Orange peel, knockdown, smooth, and popcorn texture matching',
  'Drywall repair before painting',
  'Paint touch-up or repaint after patch'
];

const processSteps = [
  { title: 'Send photos', text: 'Upload a few clear photos and describe the drywall issue.' },
  { title: 'We review scope', text: 'Our team checks size, texture, finish, and whether a call or visit is needed.' },
  { title: 'Repair + blend', text: 'When approved, we patch the wall or ceiling and help blend the visible finish.' }
];

const faqs = [
  { q: 'Can you estimate drywall repair from photos?', a: 'Many drywall repairs can be estimated faster when you send clear photos and a short description. Larger repairs, ceiling damage, water stains, or texture/paint matching may require a quick call or in-person visit before final pricing.' },
  { q: 'Do you also paint after the drywall patch?', a: 'Yes. The point is not just closing the hole — it is helping the repair blend with the surrounding wall or ceiling when painting is needed.' },
  { q: 'Can you match my wall or ceiling texture?', a: 'We can help with common textures including orange peel, knockdown, smooth finishes, and popcorn ceiling texture. Exact matching depends on the existing surface and age of the finish.' },
  { q: 'Do you repair water-damaged drywall?', a: 'We can repair water-damaged drywall once the source of the leak or moisture has been handled. Active leaks or mold concerns need to be addressed first.' },
  { q: 'What areas of South Charlotte do you serve?', a: 'We serve South Charlotte, Ballantyne, Pineville, Matthews, and nearby Charlotte-area neighborhoods.' }
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Drywall Repair + Paint Matching in South Charlotte',
  description,
  serviceType: 'Drywall repair and paint matching',
  url: `https://ifixxnc.com${canonical}`,
  image: `https://ifixxnc.com${heroImage}`,
  provider: { '@id': 'https://ifixxnc.com/#business' },
  areaServed: ['South Charlotte', 'Ballantyne', 'Pineville', 'Matthews'],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ifixxnc.com/' },
    { '@type': 'ListItem', position: 2, name: 'Drywall Repair South Charlotte', item: `https://ifixxnc.com${canonical}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.q,
    acceptedAnswer: { '@type': 'Answer', text: faq.a }
  }))
};
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={heroImage}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="Drywall repair patching and spackling by iFIXX" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/85 to-neutral-900/55"></div>
    </div>

    <div class="container relative z-10">
      <div class="py-10 lg:py-16">
        <nav class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-neutral-300">
            <li><a href="/" class="hover:text-primary-500 transition-colors">Home</a></li>
            <li class="text-neutral-500">/</li>
            <li class="text-white font-medium">Drywall Repair South Charlotte</li>
          </ol>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <div class="order-1 lg:order-1">
            <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">
              South Charlotte • Ballantyne • Pineville • Matthews
            </span>
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4">
              Drywall Repair + Paint Matching in South Charlotte
            </h1>
            <p class="text-lg text-neutral-200 mb-6 max-w-xl">
              Send us photos of the damage and our local iFIXX team will help you figure out the fastest path to repair — from holes, cracks, nail pops, and ceiling damage to texture matching and paint blending.
            </p>
            <div class="flex flex-col sm:flex-row gap-3 mb-8">
              <a href="#estimate-form" class="btn btn-primary landing-primary-cta" data-lead-type={leadType}>Request a Photo Estimate</a>
              <a href="tel:+19803916833" class="btn btn-outline-light landing-phone-cta" data-lead-type={leadType}>Call (980) 391-6833</a>
            </div>
            <div class="grid grid-cols-2 gap-4">
              {['Local South Charlotte team', 'Photo-first estimates', 'Drywall + paint finish', 'Insured'].map((chip) => (
                <div class="flex items-center gap-3 text-white">
                  <span class="w-9 h-9 rounded-full bg-primary-500/20 flex items-center justify-center text-primary-400">✓</span>
                  <span class="text-sm font-medium">{chip}</span>
                </div>
              ))}
            </div>
          </div>

          <div id="estimate-form" class="order-2 lg:order-2 scroll-mt-24 min-w-0">
            <LandingEstimateForm
              serviceSlug="drywall-repair"
              serviceTitle="Drywall Repair + Paint Matching"
              formId="drywall-south-charlotte-estimate"
              leadType="drywall_repair"
              formName="South Charlotte Drywall Repair Landing Form"
              issueOptions={['hole', 'crack', 'ceiling damage', 'water stain/damage', 'texture matching', 'paint matching', 'nail pops', 'other']}
              descriptionPlaceholder="Briefly describe the drywall issue."
              photoLabel="Upload photos of the damage"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="badge mb-4">Drywall + finish repair</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-6">We repair and blend the finish</h2>
          <p class="text-neutral-600 mb-8">The visible mismatch after a patch is the real pain. iFIXX helps with the repair and the finish so you are not hiring one crew for drywall and another for paint.</p>
          <ul class="space-y-4">
            {repairItems.map((item) => (
              <li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-2xl">
          <img src={supportImage} alt="Finished drywall and paint blending project" class="w-full aspect-[4/3] object-cover" width="700" height="525" loading="lazy" decoding="async" />
        </div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="badge mb-4">Don’t hire twice</span>
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Patch + paint blending in one clear scope</h2>
        <p class="text-neutral-600">A cheap patch that leaves a visible square is not finished work. Send photos first so we can understand the repair, texture, and repaint needs before recommending the next step.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
        {processSteps.map((step, index) => (
          <div class="card p-6 text-center">
            <div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center font-heading font-bold text-neutral-900 text-xl">{index + 1}</div>
            <h3 class="font-heading font-bold text-neutral-900 mb-2">{step.title}</h3>
            <p class="text-sm text-neutral-600">{step.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-4xl mx-auto bg-neutral-900 rounded-2xl p-8 lg:p-10 text-white shadow-xl">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold mb-4">Can this be estimated from photos?</h2>
        <p class="text-neutral-200 text-lg">Many drywall repairs can be estimated faster when you send clear photos and a short description. For larger repairs, ceiling damage, water stains, or matching texture/paint, we may recommend a quick phone call or in-person visit before final pricing.</p>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">Drywall Repair FAQs</h2>
        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <details class="group bg-white rounded-xl shadow-sm" open={index === 0}>
              <summary class="flex items-center justify-between cursor-pointer list-none p-6"><span class="font-semibold text-neutral-900 pr-4">{faq.q}</span><span class="text-primary-600 group-open:rotate-180 transition-transform">⌄</span></summary>
              <div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <GoogleReviews title="What Charlotte Homeowners Say" />

  <CTASection
    headline="Ready to repair the wall and blend the finish?"
    subtext="Request a photo estimate for drywall patching, ceiling repair, texture matching, and paint touch-ups in South Charlotte."
  />

  <script is:inline>
    document.addEventListener('click', (event) => {
      const cta = event.target.closest('.landing-primary-cta');
      const phone = event.target.closest('.landing-phone-cta');
      if (!cta && !phone) return;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: cta ? 'landing_cta_click' : 'phone_click',
        lead_type: 'drywall_repair',
        campaign_test: 'ifixx_south_charlotte_service_test_2026_07',
        form_location: window.location.pathname
      });
    });
  </script>
</BaseLayout>
