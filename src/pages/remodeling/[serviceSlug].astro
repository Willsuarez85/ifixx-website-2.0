            document.querySelectorAll('input[name="package"]').forEach(function (input) {
              input.value = pkg;
            });
            document.querySelectorAll('textarea[name="message"]').forEach(function (ta) {
              if (!ta.value.trim()) ta.value = "I'm interested in the " + pkgName + ' package.';
            });
            if (typeof gtag !== 'undefined') {
              gtag('event', 'select_package', {
                'package': pkg,
                'page_location_path': window.location.pathname
              });
            }
            var heroForm = document.querySelector('[data-form-wrapper]');
            if (heroForm) heroForm.scrollIntoView({ behavior: 'smooth', block: 'center' });
