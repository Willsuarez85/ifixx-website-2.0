---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import CTAIntermediate from '../../components/sections/CTAIntermediate.astro';
import CTASection from '../../components/sections/CTASection.astro';
import QuickEstimateCompact from '../../components/forms/QuickEstimateCompact.astro';
import ScrollGallery from '../../components/sections/ScrollGallery.astro';
import GoogleReviews from '../../components/sections/GoogleReviews.astro';
import { isRetiredCity, isRetiredService } from '../../lib/seo-retired';

export async function getStaticPaths() {
  const services = await getCollection('services');
  // Only generate pages for services in the remodeling pillar
  const remodelingServices = services.filter(s => s.data.pillar === 'remodeling');
  return remodelingServices.map((service) => ({
    params: { serviceSlug: service.slug },
    props: { service },
  }));
}

interface Props {
  service: CollectionEntry<'services'>;
}

const { service } = Astro.props;
const { Content } = await service.render();

const { title, category, pillar, summary, heroImage, bullets, signs, processSteps, faqs, relatedServices, seo } = service.data;

// Get all services for related services lookup
const allServices = await getCollection('services');
const relatedServicesList = relatedServices
  ? allServices.filter(s => relatedServices.includes(s.slug) && s.slug !== service.slug && !isRetiredService(s.slug))
  : [];

// Get all cities for service areas section — exclude retired cities
const allCities = (await getCollection('cities')).filter(c => !isRetiredCity(c.slug));
const serviceAreas = allCities.sort((a, b) => {
  // Sort: Charlotte first, then alphabetically
  if (a.slug === 'charlotte') return -1;
  if (b.slug === 'charlotte') return 1;
  return a.data.name.localeCompare(b.data.name);
});

// Map service slugs to hero images
const serviceHeroImages: Record<string, string> = {
  'kitchen-remodeling': '/images/projects/kitchen-remodeling-complete-modern-white-cabinets-island.webp',
  'bathroom-remodeling': '/images/projects/bathroom-remodeling-modern-glass-shower-vanity.webp',
  'basement-finishing': '/images/projects/living-room-fireplace-white-brick.webp',
  'flooring-installation': '/images/projects/flooring-installation-modern-living-room-interior.webp',
  'outdoor-living': '/images/projects/outdoor-living-deck-construction-screened-porch.webp',
  'home-additions': '/images/projects/construction-wood-framing-window.webp',
};

// Map service slugs to project images
const serviceProjectImages: Record<string, string> = {
  'kitchen-remodeling': '/images/projects/kitchen-remodeling-luxury-white-cabinets-island-pendant-lights.webp',
  'bathroom-remodeling': '/images/projects/bathroom-remodeling-dual-vanity-installation-progress.webp',
  'basement-finishing': '/images/projects/closet-built-in-white-organizer.webp',
  'flooring-installation': '/images/projects/bedroom-bed-wood-dressers.webp',
  'outdoor-living': '/images/projects/outdoor-living-covered-porch-deck-wood-ceiling.webp',
  'home-additions': '/images/projects/outdoor-living-raised-deck-railing-construction.webp',
};

const heroImageSrc = heroImage || serviceHeroImages[service.slug] || '/images/ui/hero-bg.jpg';
const projectImageSrc = serviceProjectImages[service.slug] || '/images/projects/Ifixx-portfolio3.webp';

// CRO 2026-07: productized Silver/Gold/Platinum packages (iFIXX's real offer,
// provided by William/Jaime 2026-07-06). Entry-level pricing stays at
// $5,000 (bath) / $8,000 (kitchen) — the packages sell the full renovations;
// the entryLine bridges smaller refreshes to a free quote.
// Cards render only name/tagline/price/size/blurb/bestFor (generic, William
// 2026-07-06). includes/exclusions stay here as the canonical spec record and
// render on-page via the markdown "Costs & Investment" mirror — if prices or
// specs change, update BOTH this data and the markdown.
// level 1-3 frames the tiers as escalating levels of transformation of the
// same space; names are descriptive (William 2026-07-07: no Silver/Gold/
// Platinum in customer-facing copy). The internal `value` keys STAY
// silver/gold/platinum because GHL tags (package-{value}) and the estimator
// pipeline depend on them. image = real portfolio photo matching each level.
interface RemodelPackage {
  name: string; price: string; size: string; blurb: string;
  includesLabel: string; includes: string[]; exclusions?: string; bestFor: string; value: string;
  level: 1 | 2 | 3; levelLabel: string; image: string; imageAlt: string;
}
const servicePackages: Record<string, { packages: RemodelPackage[]; entryLine: string; guideUrl: string; guideLabel: string }> = {
  'kitchen-remodeling': {
    entryLine: 'Planning a smaller update? Kitchen refreshes start at $8,000, measured and quoted free.',
    guideUrl: '/blog/how-much-kitchen-remodel-charlotte',
    guideLabel: 'Read our full Charlotte kitchen remodel cost guide',
    packages: [
      {
        name: 'Functional Refresh', price: 'Starting at $10K', size: "Standard size: 10'x10'", value: 'silver',
        level: 1, levelLabel: 'Refresh',
        image: '/images/projects/Ifixx-portfolio11.webp',
        imageAlt: 'Functional refresh kitchen remodel with white cabinets and subway tile backsplash, Charlotte NC',
        blurb: 'We take care of everything for you: countertops, paint, hardware, materials shopping and installation.',
        includesLabel: 'Includes',
        includes: ['Fresh wall paint', "Up to 12 basic cabinets (Home Depot/Lowe's, no soft-close)", 'Standard granite countertops', 'Subway tile backsplash', 'Stainless steel sink + faucet', 'Basic knobs and hardware'],
        exclusions: 'Exclusions: appliances, plumbing relocation, permits.',
        bestFor: 'Best for homeowners who want a simple, functional update at an affordable price.',
      },
      {
        name: 'Complete Renovation', price: 'Starting at $20K', size: "Standard size: 10'x10'", value: 'gold',
        level: 2, levelLabel: 'Full Renovation',
        image: '/images/projects/kitchen-remodeling-complete-modern-white-cabinets-island.webp',
        imageAlt: 'Complete kitchen renovation with new cabinets, counters and island, Charlotte NC',
        blurb: 'Renovates the whole kitchen: solid wood cabinets, quartz counters, better everything.',
        includesLabel: 'Includes',
        includes: ['Up to 20 NKBC wood cabinets (100% wood, soft-close)', 'Quartz or premium granite countertops (#1 grade)', 'Custom backsplash', 'Farmhouse sink + garbage disposal', 'Premium hardware', 'Plumbing upgrades (coordinated & to code)'],
        exclusions: 'Exclusions: major layout changes, high-end custom finishes, appliances.',
        bestFor: 'Best for families ready to invest in a durable, stylish kitchen that adds value.',
      },
      {
        name: 'Luxury Custom Kitchen', price: 'Starting at $35K', size: 'Custom size/layout', value: 'platinum',
        level: 3, levelLabel: 'Total Transformation',
        image: '/images/projects/Ifixx-portfolio63.webp',
        imageAlt: 'Luxury custom kitchen remodel with marble waterfall island, Charlotte NC',
        blurb: 'Rebuilds the kitchen around you: custom layout, luxury finishes, one of a kind.',
        includesLabel: 'Everything in Gold PLUS',
        includes: ['Designer quartz or imported stone countertops', 'Large island with special features', 'Decorative or integrated lighting', 'Optional high-end appliances and accessories', 'Fully custom layout and finishes'],
        bestFor: 'Best for homeowners who want a luxury, one-of-a-kind kitchen tailored to their lifestyle.',
      },
    ],
  },
  'bathroom-remodeling': {
    entryLine: 'Planning a smaller refresh? Bathroom updates start at $5,000, measured and quoted free.',
    guideUrl: '/blog/how-much-bathroom-remodel-charlotte',
    guideLabel: 'Read our full Charlotte bathroom remodel cost guide',
    packages: [
      {
        name: 'Refreshing Update', price: 'Starting at $10K', size: "Standard size: 5'x10'", value: 'silver',
        level: 1, levelLabel: 'Refresh',
        image: '/images/projects/Ifixx-portfolio28.webp',
        imageAlt: 'Refreshed bathroom with updated vanity, fixtures and finishes, Charlotte NC',
        blurb: 'Refreshes the bathroom you have: modern look, same layout, no structural changes.',
        includesLabel: 'Includes',
        includes: ['New wall paint', 'Vanity + up to 2 new lights', 'Basic faucet & hardware', 'Decorative tile above the tub (no tub-to-shower conversion)', 'Flooring: luxury vinyl (LVP) or 12"x24" ceramic tile'],
        exclusions: 'Exclusions: shower glass, plumbing relocation, permits.',
        bestFor: 'Best for homeowners who want a clean, budget-friendly update.',
      },
      {
        name: 'Complete Renovation', price: 'Starting at $20K', size: "Standard size: 5'x10'", value: 'gold',
        level: 2, levelLabel: 'Full Renovation',
        image: '/images/projects/bathroom-remodeling-modern-glass-shower-vanity.webp',
        imageAlt: 'Complete bathroom renovation with tub-to-shower conversion, tile to the ceiling and glass, Charlotte NC',
        blurb: 'Renovates the full bathroom: tub-to-shower conversion, tile to the ceiling, new everything.',
        includesLabel: 'Includes',
        includes: ['Tub-to-shower conversion with tile up to the ceiling', 'Custom shower niche and/or bench', 'Shower pan tile', 'Upgraded vanity, sink, faucet, and lighting', 'Flooring: premium ceramic tile or LVP', 'Frameless shower glass', 'Full plumbing upgrades (coordinated & to code) + new ventilation'],
        exclusions: 'Exclusions: major layout changes, wall relocations, luxury/custom finishes.',
        bestFor: 'Best for homeowners who want the full transformation. Done once, done right.',
      },
      {
        name: 'Spa Experience', price: 'Starting at $30K', size: 'Custom size/layout', value: 'platinum',
        level: 3, levelLabel: 'Total Transformation',
        image: '/images/projects/bathroom-1.webp',
        imageAlt: 'Spa style bathroom remodel with freestanding tub and double vanity, Charlotte NC',
        blurb: 'Rebuilds it as your private spa: custom layout, designer finishes, one of a kind.',
        includesLabel: 'Everything in Gold PLUS',
        includes: ['Quartz or large-format porcelain surfaces', 'Designer fixtures and lighting features', 'Double vanity / spa shower options', 'Fully customized layout and finishes'],
        bestFor: 'Best for homeowners who want a one-of-a-kind, spa-inspired bathroom.',
      },
    ],
  },
};
const packageData = servicePackages[service.slug] || null;

// kitchen/bathroom (and painting/drywall) are consolidated services: they do NOT
// generate city×service pages, so Service Areas must link to the city hub pages
// instead of URLs that 308-redirect back here.
const consolidatedServices = ['kitchen-remodeling', 'bathroom-remodeling', 'painting', 'drywall'];
const isConsolidated = consolidatedServices.includes(service.slug);

// Service schema with pillar URL structure
const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": title,
  "description": seo.description,
  "serviceType": title,
  "url": `https://www.ifixxnc.com/remodeling/${service.slug}/`,
  "image": `https://www.ifixxnc.com${heroImageSrc}`,
  "provider": {
    "@type": ["LocalBusiness", "HomeAndConstructionBusiness"],
    "@id": "https://www.ifixxnc.com/#business",
    "name": "iFixx Remodeling & Handyman Services",
    "url": "https://www.ifixxnc.com",
    "telephone": "+1-980-391-6833",
    "email": "ifixx.hs@gmail.com",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Charlotte",
      "addressRegion": "NC",
      "addressCountry": "US"
    }
  },
  "areaServed": [
    {
      "@type": "City",
      "name": "Charlotte",
      "containedInPlace": {
        "@type": "State",
        "name": "North Carolina"
      }
    },
    {
      "@type": "City",
      "name": "Ballantyne",
      "containedInPlace": {
        "@type": "State",
        "name": "North Carolina"
      }
    },
    {
      "@type": "City",
      "name": "Matthews",
      "containedInPlace": {
        "@type": "State",
        "name": "North Carolina"
      }
    },
    {
      "@type": "City",
      "name": "Mint Hill",
      "containedInPlace": {
        "@type": "State",
        "name": "North Carolina"
      }
    },
    {
      "@type": "City",
      "name": "Concord",
      "containedInPlace": {
        "@type": "State",
        "name": "North Carolina"
      }
    },
    {
      "@type": "City",
      "name": "Monroe",
      "containedInPlace": {
        "@type": "State",
        "name": "North Carolina"
      }
    },
    {
      "@type": "City",
      "name": "Pineville",
      "containedInPlace": {
        "@type": "State",
        "name": "North Carolina"
      }
    },
    {
      "@type": "City",
      "name": "Rock Hill",
      "containedInPlace": {
        "@type": "State",
        "name": "South Carolina"
      }
    },
    {
      "@type": "City",
      "name": "Waxhaw",
      "containedInPlace": {
        "@type": "State",
        "name": "North Carolina"
      }
    }
  ],
  "offers": {
    "@type": "AggregateOffer",
    "availability": "https://schema.org/InStock",
    "priceCurrency": "USD",
    "lowPrice": service.slug === 'kitchen-remodeling' ? "8000" : (service.slug === 'bathroom-remodeling' ? "5000" : "500"),
    "highPrice": service.slug === 'kitchen-remodeling' ? "60000" : (service.slug === 'bathroom-remodeling' ? "40000" : "10000")
  },

};

// Breadcrumb schema with pillar structure
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://www.ifixxnc.com"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Remodeling",
      "item": "https://www.ifixxnc.com/remodeling/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title,
      "item": `https://www.ifixxnc.com/remodeling/${service.slug}/`
    }
  ]
};

// FAQ schema
const faqSchema = faqs && faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.a
    }
  }))
} : null;

// Helper function to get the correct URL for a service based on its pillar
const getServiceUrl = (serviceSlug: string, servicePillar?: string) => {
  const pillars: Record<string, string> = {
    'repairs': '/repairs/',
    'remodeling': '/remodeling/',
    'emergency-services': '/emergency-services/'
  };
  const basePath = servicePillar ? pillars[servicePillar] || '/services/' : '/services/';
  return `${basePath}${serviceSlug}`;
};
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  canonical={`/remodeling/${service.slug}/`}
>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
  </Fragment>

  <!-- Hero Section with Side-by-Side Form -->
  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src={heroImageSrc}
        alt={`${title} services in Charlotte NC - iFixx professional team`}
        class="w-full h-full object-cover"
        width="1920"
        height="1080"
        fetchpriority="high"
        decoding="async"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/85 to-neutral-900/60"></div>
    </div>

    <div class="container relative z-10">
      <div class="py-12 lg:py-20">
        <!-- Breadcrumb -->
        <nav class="mb-6">
          <ol class="flex items-center gap-2 text-sm text-neutral-300">
            <li><a href="/" class="hover:text-primary-500 transition-colors">Home</a></li>
            <li class="text-neutral-500">/</li>
            <li><a href="/remodeling" class="hover:text-primary-500 transition-colors">Remodeling</a></li>
            <li class="text-neutral-500">/</li>
            <li class="text-white font-medium">{title}</li>
          </ol>
        </nav>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <!-- Content Side — first on every breakpoint: mobile users must see
               the H1/value prop before the form (William 2026-07-06) -->
          <div>
            <!-- Category Badge -->
            <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">
              Remodeling Service
            </span>

            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4">
              Professional {title} in Charlotte, NC
            </h1>

            <p class="text-lg text-neutral-200 mb-6 max-w-xl">
              {summary}
            </p>

            <!-- Benefit Icons -->
            <div class="grid grid-cols-2 gap-4 mb-8">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-500/20 flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <span class="text-sm text-white font-medium">Quality Craftsmanship</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-500/20 flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                  </svg>
                </div>
                <span class="text-sm text-white font-medium">On-Time Delivery</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-500/20 flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                </div>
                <span class="text-sm text-white font-medium">Local Charlotte Team</span>
              </div>
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-primary-500/20 flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                  </svg>
                </div>
                <span class="text-sm text-white font-medium">Fully Insured</span>
              </div>
            </div>

            <!-- Phone CTA -->
            <a href="tel:+19803916833" class="inline-flex items-center gap-3 text-white hover:text-primary-400 transition-colors">
              <div class="w-12 h-12 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-6 h-6 text-neutral-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <p class="text-sm text-neutral-400">Schedule a consultation</p>
                <p class="text-xl font-heading font-bold">(980) 391-6833</p>
              </div>
            </a>
          </div>

          <!-- Form Side -->
          <div>
            <QuickEstimateCompact
              serviceSlug={service.slug}
              serviceTitle={title}
              formId={`hero-estimate-${service.slug}`}
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <TrustBar variant="light" />

  <!-- Project Gallery — moved above the fold content (CRO 2026-07): remodeling
       sells with eyes; real project photos come before any long-form copy -->
  <ScrollGallery
    serviceSlug={service.slug}
    title={`Real ${title} Projects in Charlotte`}
  />

  {packageData && (
    <!-- Silver/Gold/Platinum packages — iFIXX's productized offer. Answers the
         #1 buyer question with real packages; per-package CTA pre-selects the
         package into the estimate form (GHL tag package-{value}) -->
    <section class="section" id="packages">
      <div class="container">
        <div class="max-w-3xl mx-auto text-center mb-10">
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-3">
            Choose Your Level of Transformation
          </h2>
          <p class="text-neutral-600 mb-2">
            Every project is one of <strong class="text-neutral-900">three levels of transformation</strong> for the same space. Level 1 refreshes what you have. Level 2 renovates it completely. Level 3 rebuilds it custom, around you.
          </p>
          <p class="text-neutral-600">
            Real prices, no guesswork. Every quote is measured at your home and itemized for free.
          </p>
        </div>

        <!-- Cards are intentionally generic (William 2026-07-06): tier + starting
             price + what it's about. The full spec lists stay in the markdown
             "Costs & Investment" accordion (kept as the on-page mirror). -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-6xl mx-auto mb-6">
          {packageData.packages.map((pkg, i) => (
            <div class={`rounded-2xl border overflow-hidden flex flex-col bg-white ${i === 1 ? 'border-primary-500 shadow-xl' : 'border-neutral-200 shadow-sm'}`}>
              <!-- Real project photo matching the level's finish -->
              <div class="relative">
                <img
                  src={pkg.image}
                  alt={pkg.imageAlt}
                  class="w-full h-44 object-cover"
                  width="600"
                  height="338"
                  loading="lazy"
                  decoding="async"
                />
                <span class="absolute top-3 left-3 bg-neutral-900/85 backdrop-blur-sm text-white text-xs font-bold px-3 py-1 rounded-full">
                  Level {pkg.level} · {pkg.levelLabel}
                </span>
              </div>
              <div class={`px-6 py-4 text-center ${i === 1 ? 'bg-primary-500' : 'bg-neutral-900'}`}>
                {i === 1 && (
                  <span class="inline-block bg-neutral-900 text-white text-xs font-bold px-3 py-1 rounded-full mb-2">
                    Most Popular
                  </span>
                )}
                <h3 class={`font-heading font-bold text-2xl ${i === 1 ? 'text-neutral-900' : 'text-white'}`}>{pkg.name}</h3>
              </div>
              <div class="p-6 flex flex-col flex-1 text-center">
                <p class="text-3xl font-heading font-bold text-neutral-900">{pkg.price}</p>
                <p class="text-sm text-neutral-500 mb-4">{pkg.size}</p>
                <!-- Transformation meter: how far this level takes the space -->
                <div class="flex items-center justify-center gap-1.5 mb-1" aria-hidden="true">
                  {[1, 2, 3].map((n) => (
                    <span class={`h-1.5 w-8 rounded-full ${n <= pkg.level ? 'bg-primary-500' : 'bg-neutral-200'}`}></span>
                  ))}
                </div>
                <p class="text-xs uppercase tracking-wide text-neutral-500 mb-4">Transformation level {pkg.level} of 3</p>
                <p class="text-sm text-neutral-600 mb-3">{pkg.blurb}</p>
                <p class="text-sm text-neutral-600 mb-6">{pkg.bestFor}</p>
                <button
                  type="button"
                  class="package-cta w-full btn btn-primary justify-center font-bold whitespace-nowrap mt-auto"
                  data-package={pkg.value}
                  data-package-name={pkg.name}
                >
                  Get My Free Quote
                </button>
