            // Group the long-form markdown into <details> accordions by H2.
            (function () {
              var root = document.getElementById('seo-content-accordion');
              if (!root) return;
              var nodes = Array.from(root.childNodes);
              var frag = document.createDocumentFragment();
              var currentDetails = null;
              var currentBody = null;
              var isFirst = true;
              nodes.forEach(function (node) {
                if (node.nodeType === 1 && node.tagName === 'H2') {
                  currentDetails = document.createElement('details');
                  currentDetails.className = 'group bg-neutral-50 rounded-xl mb-3 border border-neutral-100';
                  if (isFirst) { currentDetails.open = true; isFirst = false; }
                  var summary = document.createElement('summary');
                  summary.className = 'flex items-center justify-between cursor-pointer list-none px-5 py-4 font-heading font-semibold text-neutral-900';
                  summary.innerHTML = '<span class="pr-4">' + node.textContent + '</span>' +
                    '<svg class="w-5 h-5 text-primary-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>';
                  currentBody = document.createElement('div');
                  currentBody.className = 'px-5 pb-5';
                  currentDetails.appendChild(summary);
                  currentDetails.appendChild(currentBody);
                  frag.appendChild(currentDetails);
                } else if (currentBody) {
                  currentBody.appendChild(node);
                } else {
                  frag.appendChild(node); // intro text before the first H2 stays visible
                }
              });
              root.innerHTML = '';
              root.appendChild(frag);
            })();
          </script>

