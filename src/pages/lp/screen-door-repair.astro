---
import LandingLayout from '../../layouts/LandingLayout.astro';
import LandingForm from '../../components/forms/LandingForm.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ScrollGallery from '../../components/sections/ScrollGallery.astro';
import GoogleReviews from '../../components/sections/GoogleReviews.astro';

const heroImage = "/images/projects/screen-door-sliding-track-roller-repair.webp";

const seo = {
  title: "Screen Door Repair Charlotte NC | Sliding & Swing Door Specialists | iFIXX",
  description: "Screen door repair Charlotte NC — sliding door off-track, swing door springs, torn mesh, bent frames. Family-owned, insured, same-day available. Call (980) 391-6833."
};

const services = [
  { icon: "🚪", title: "Sliding Screen Door Track & Roller Repair", desc: "Door won't slide, jumps off the track, or fights you every time? We replace rollers, clean tracks, and realign so it glides like new.", image: "/images/projects/screen-door-sliding-track-roller-repair.webp" },
  { icon: "🔩", title: "Swing Screen Door Spring & Hinge Repair", desc: "Door slams shut, won't close, or sags off the hinge? Spring, closer, hinge, and latch — all repairable, no full replacement needed.", image: "/images/projects/screen-door-swing-spring-hinge-replacement.webp" },
  { icon: "🧵", title: "Screen Door Mesh Replacement", desc: "Torn or popped-out mesh on sliding or swing doors. Standard fiberglass or upgraded aluminum mesh — rescreened on-site.", image: "/images/projects/window-screen-rescreen-mesh-spline-roller.webp" },
  { icon: "📐", title: "Bent or Warped Door Frame Repair", desc: "Aluminum frame bent from a kick, slam, or weather? Reshape, weld, or replace the affected section without buying a new door.", image: "/images/projects/window-screen-frame-bent-repair-aluminum.webp" },
  { icon: "🐕", title: "Pet-Resistant Screen Door Mesh", desc: "Dogs or cats shredding your screen? Heavy-gauge pet mesh: 7× stronger than standard, transparent, scratch-resistant.", image: "/images/projects/pet-screen-heavy-gauge-mesh-dog-resistant.webp" },
  { icon: "🛠️", title: "Quick Screen Door Patches & Adjustments", desc: "Small tears, loose handles, latches that won't catch, mis-aligned doors — minor fixes done in one visit, often same-day.", image: "/images/projects/screen-patch-small-tear-repair-quick-fix.webp" },
];

const whyChooseUs = [
  { title: "Talk to the Owners", desc: "When you call, Jaime or Hamed answer. No dispatchers, no call centers, no runaround." },
  { title: "No $99 Trip Charge", desc: "The big franchises charge $99 just to look at your door. We don't. Free estimate, no obligation." },
  { title: "Same-Day Available", desc: "Most screen door repairs done in one visit. Call before 10am for best chance at same-day." },
  { title: "Repair First, Replace Last", desc: "Big-box stores push you to buy a $400 new door. Most doors just need rollers, a hinge, or new mesh — under $150." },
  { title: "We Make It Right", desc: "If something's not perfect, we fix it. That's not a policy — that's just how we work." },
  { title: "Fully Insured", desc: "Full liability coverage on every project. Your home is protected, and so are we." },
];

const processSteps = [
  { title: "Tell Us What's Wrong", description: "Call, text, or fill out our form. Send a photo of the door, the track, or the broken part — saves the diagnostic visit." },
  { title: "Get a Free Estimate", description: "We confirm the parts, the labor, and the price up front. No surprises mid-job." },
  { title: "We Fix It", description: "Most screen door repairs done in one visit. Clean up after. Door that opens, closes, and locks like new." },
];

const faqs = [
  { q: "My sliding screen door keeps jumping off the track. Can it be fixed?", a: "Yes — almost always. Sliding door issues usually come down to worn or broken rollers, a debris-clogged track, or a bent frame at the corner. We replace the rollers, clean and align the track, and the door glides like new. Full replacement is rarely necessary." },
  { q: "My swing screen door won't close or slams shut — what's broken?", a: "Sounds like the spring or pneumatic closer. The closer at the top of the door controls the speed; when it fails the door either slams or won't close. We replace closers, springs, and hinges in one visit — usually under $120." },
  { q: "Do I need to replace the whole screen door or can it be repaired?", a: "Most of the time, repair. Bent frames can be straightened, torn mesh re-screened, rollers and hardware swapped — way cheaper than a new door. We'll give you an honest recommendation: if the door is shot, we'll say so; if a $90 part fixes it, we'll do that instead." },
  { q: "My dog destroyed the screen on my patio door. Can you replace it with something stronger?", a: "Yes — pet-resistant mesh is one of our most-requested upgrades. It's a heavy-gauge polyester weave, roughly 7× stronger than standard fiberglass mesh, scratch-resistant, and still nearly invisible. We can rescreen your existing door in pet mesh in under an hour." },
  { q: "Do you fix custom-size or non-standard screen doors?", a: "Yes. Older homes in Charlotte often have non-standard door openings — we measure, fit, and repair custom sizes on-site. If a part isn't available off-the-shelf, we source or fabricate it." },
  { q: "How fast can you come out?", a: "Same-day available for most screen door jobs in Charlotte, Ballantyne, Matthews, Concord, and surrounding areas. Call before 10am for best chance. After-hours? Leave a voicemail or chat with our virtual assistant — we respond first thing." },
];
---

<LandingLayout title={seo.title} description={seo.description} canonical="/lp/screen-door-repair">

  <!-- Hero -->
  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="Screen door repair specialist in Charlotte fixing sliding patio door" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/80 to-neutral-900/40"></div>
    </div>
    <div class="container relative z-10">
      <div class="py-12 lg:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <div class="order-1 lg:order-1">
            <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">Charlotte's Screen Door Specialists</span>
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4 leading-tight">
              Screen Door Repair <span class="text-primary-500">Charlotte NC</span> — Sliding, Swing, Torn or Stuck? We Fix It.
            </h1>
            <p class="text-lg text-neutral-200 mb-6 max-w-xl">
              Sliding doors off the track, swing doors that won't close, torn mesh, bent frames, pet damage — <strong class="text-white">one team fixes every part of your screen door.</strong> Family-owned, insured, 500+ projects across Charlotte, Ballantyne, Matthews & Concord.
            </p>

            <div class="grid grid-cols-3 gap-4 mb-8">
              <div class="bg-white/5 rounded-lg p-4 text-center">
                <p class="text-3xl font-heading font-bold text-primary-500">500+</p>
                <p class="text-white/80 text-sm">Projects Done</p>
              </div>
              <div class="bg-white/5 rounded-lg p-4 text-center">
                <p class="text-3xl font-heading font-bold text-primary-500">5.0</p>
                <p class="text-white/80 text-sm">Google Rating</p>
              </div>
              <div class="bg-white/5 rounded-lg p-4 text-center">
                <p class="text-3xl font-heading font-bold text-primary-500">Insured</p>
                <p class="text-white/80 text-sm">Fully Covered</p>
              </div>
            </div>

            <a href="tel:+19803916833" class="inline-flex items-center gap-3 text-white hover:text-primary-400 transition-colors">
              <div class="w-12 h-12 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-6 h-6 text-neutral-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <p class="text-sm text-neutral-300">Call us now</p>
                <p class="text-xl font-heading font-bold">(980) 391-6833</p>
              </div>
            </a>
            <p class="text-sm text-neutral-300 mt-2">After hours? Leave a voicemail or chat with our virtual assistant — we respond fast.</p>
          </div>
          <div class="order-2 lg:order-2">
            <LandingForm formId="lp-screen-door-hero" formName="Landing Page - Screen Door Repair" servicePreselect="screen-repair" ctaText="Get Free Estimate" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <!-- Problem / Solution -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block px-4 py-2 bg-red-100 text-red-700 text-sm font-bold rounded-full mb-4">Sound Familiar?</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Living With a Broken Screen Door</h2>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex gap-3"><span class="text-red-500">✗</span> Sliding patio door that jumped off the track</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Swing door that slams shut — or won't shut at all</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Torn mesh you've taped up "temporarily" for months</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Bent frame from a kick, slam, or storm</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Pet that shredded the bottom panel</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Latch or handle that won't catch — door won't stay closed</li>
          </ul>
        </div>
        <div>
          <span class="inline-block px-4 py-2 bg-green-100 text-green-700 text-sm font-bold rounded-full mb-4">The Fix</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Repair First. Replace Only When We Have To.</h2>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Tracks, rollers, springs, hinges, mesh, frames — <strong>one team handles all of it</strong></li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> No $99 trip charge — the franchises bill you just to look, we don't</li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Honest repair-vs-replace — <strong>most doors don't need to be replaced</strong></li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Same-day for most jobs in Charlotte metro</li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Insured, upfront priced, 500+ projects done</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section-alt">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Every Screen Door Problem We Fix</h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">From a stuck slider to a torn mesh to a broken closer — one call covers it all.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {services.map((service) => (
          <div class="card group overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" width="400" height="300" />
            </div>
            <div class="p-6">
              <h3 class="font-heading font-bold text-neutral-900 mb-2 flex items-center gap-2"><span class="text-xl">{service.icon}</span> {service.title}</h3>
              <p class="text-sm text-neutral-600">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ScrollGallery title="Recent Screen Door Projects" serviceSlug="window-repair" />

  <!-- CTA Banner -->
  <section class="py-10 md:py-14 bg-gradient-to-r from-primary-600 to-primary-500">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
        <div class="text-center lg:text-left max-w-2xl">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-2">Stop Living With a Broken Screen Door</h2>
          <p class="text-lg text-primary-100">Free estimate, same-day available, no obligation, no $99 trip charge.</p>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a href="#lp-screen-door-hero" class="btn px-8 py-4 text-lg font-bold rounded-lg bg-neutral-900 text-white hover:bg-neutral-800">Get Free Estimate</a>
          <a href="tel:+19803916833" class="flex items-center gap-2 font-bold text-white hover:text-white/80"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg><span class="underline">(980) 391-6833</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section">
    <div class="container">
      <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 text-center mb-10">Why Charlotte Homeowners Choose iFIXX for Screen Door Repair</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {whyChooseUs.map((item) => (
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-secondary-50 flex items-center justify-center">
              <svg class="w-6 h-6 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            </div>
            <div>
              <h3 class="text-lg font-heading font-semibold text-neutral-900 mb-1">{item.title}</h3>
              <p class="text-neutral-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">How It Works</h2>
        <p class="text-neutral-600">Three simple steps to a screen door that works again.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {processSteps.map((step, index) => (
          <div class="text-center relative">
            {index < processSteps.length - 1 && (<div class="hidden md:block absolute top-8 left-1/2 w-full h-0.5 bg-primary-200"></div>)}
            <div class="relative"><div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center shadow-lg"><span class="text-2xl font-heading font-bold text-neutral-900">{index + 1}</span></div></div>
            <h3 class="text-lg font-heading font-semibold text-neutral-900 mb-2">{step.title}</h3>
            <p class="text-neutral-600 text-sm">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <GoogleReviews title="What Charlotte Homeowners Say" />

  <!-- About -->
  <section class="section section-alt">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img src="/images/ui/team.webp" alt="iFIXX team — Jaime & Hamed" class="w-full h-auto object-cover aspect-[4/3]" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -right-4 bg-white rounded-xl shadow-xl p-4 hidden lg:block">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-5 h-5 text-neutral-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div>
                <p class="font-heading font-bold text-neutral-900 text-sm">500+ Projects</p>
                <p class="text-xs text-neutral-600">Completed in Charlotte</p>
              </div>
            </div>
          </div>
        </div>
        <div>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Not a Franchise. Your Neighbors.</h2>
          <p class="text-neutral-600 mb-4">We're Jaime and Hamed — a Charlotte family that's been fixing homes for over 5 years. Screen door repair is one of our favorite jobs because the franchises charge you $99 just to come look, and the big-box stores push you to buy a $400 new door when really you just need rollers, a closer, or new mesh.</p>
          <p class="text-neutral-600 mb-4">Our promise is simple: <strong>answer the phone, show up on time, do quality work, and charge a fair price.</strong> That's it. That's the whole business model.</p>
          <p class="text-neutral-600">We live in Charlotte, we work in Charlotte, and we've built our reputation one project at a time — 500+ and counting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <details class="group bg-white rounded-xl shadow-sm border border-neutral-100" open={index === 0}>
              <summary class="flex items-center justify-between cursor-pointer list-none p-6">
                <span class="font-semibold text-neutral-900 pr-4">{faq.q}</span>
                <svg class="w-5 h-5 text-primary-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="section section-alt">
    <div class="container">
      <div class="text-center mb-10">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-3">Areas We Serve</h2>
        <p class="text-neutral-600">Proudly serving homeowners across the Charlotte metro area.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        {["Charlotte", "Ballantyne", "Matthews", "Concord", "Mint Hill", "Pineville", "Rock Hill", "Waxhaw"].map((city) => (
          <div class="p-4 bg-white rounded-xl border border-neutral-200 text-center">
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <span class="font-medium text-neutral-900">{city}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section bg-neutral-900">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
        <div class="text-center lg:text-left">
          <h2 class="text-3xl lg:text-4xl font-heading font-bold text-white mb-4">Get Your Screen Door Working Right</h2>
          <p class="text-lg text-white/80 mb-6">Free estimate, honest repair-vs-replace advice, no obligation.</p>
          <a href="tel:+19803916833" class="btn btn-emergency text-xl px-10 py-5 inline-flex">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (980) 391-6833
          </a>
          <p class="text-sm text-neutral-300 mt-3">After hours? Leave a message or chat with our virtual assistant.</p>
        </div>
        <div>
          <LandingForm formId="lp-screen-door-bottom" formName="Landing Page - Screen Door (Bottom)" servicePreselect="screen-repair" ctaText="Get Free Estimate" />
        </div>
      </div>
    </div>
  </section>

</LandingLayout>
