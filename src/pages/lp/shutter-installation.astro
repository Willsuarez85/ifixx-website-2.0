---
import LandingLayout from '../../layouts/LandingLayout.astro';
import LandingForm from '../../components/forms/LandingForm.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ScrollGallery from '../../components/sections/ScrollGallery.astro';
import GoogleReviews from '../../components/sections/GoogleReviews.astro';

const heroImage = "/images/projects/exterior-shutters-installation-vinyl-house-hero.webp";

const seo = {
  title: "Shutter Installation Charlotte NC | Plantation, Exterior & Hurricane Shutters | iFIXX",
  description: "Shutter installation Charlotte NC — plantation, exterior vinyl, hurricane panels, custom sizes. Local install, fair pricing, no franchise markup. Call (980) 391-6833."
};

const services = [
  { icon: "🪟", title: "Plantation Shutter Installation", desc: "Custom interior plantation shutters — real wood, faux wood, or vinyl — measured and installed for any window in your home.", image: "/images/projects/plantation-shutter-interior-louver-tilt-rod-repair.webp" },
  { icon: "🏠", title: "Exterior Vinyl Shutter Installation", desc: "Curb appeal upgrade — color-matched exterior shutters mounted clean and level on brick, vinyl, or fiber-cement siding.", image: "/images/projects/vinyl-shutter-exterior-crack-repair-mounting.webp" },
  { icon: "🌀", title: "Hurricane Shutter Installation", desc: "Aluminum panel, accordion, and Bahama hurricane shutters installed ahead of storm season. Permit-ready when needed.", image: "/images/projects/hurricane-shutter-aluminum-panel-installation.webp" },
  { icon: "📐", title: "Custom-Size Shutter Fitting", desc: "Non-standard openings, arched windows, bay windows, oversized panels — we measure, source, and install to fit.", image: "/images/projects/plantation-shutter-louver-clip-broken-fix.webp" },
  { icon: "🔧", title: "Shutter Hardware & Hinges", desc: "Sagging panels, loose hinges, broken latches, missing tilt rods — full hardware replacement or upgrade.", image: "/images/projects/shutter-hardware-hinge-bracket-replacement.webp" },
  { icon: "🎨", title: "Shutter Refinishing & Repair", desc: "Sun-faded, peeling, cracked, or scratched shutters — refinished, repainted, or panel-swapped without full replacement.", image: "/images/projects/shutter-painting-refinishing-exterior-charcoal.webp" },
];

const whyChooseUs = [
  { title: "Talk to the Owners", desc: "When you call, Jaime or Hamed answer. No franchise call center, no commissioned salesperson at your door." },
  { title: "Local Install Crew", desc: "Same person measures, quotes, and installs. No handoffs, no surprises on install day." },
  { title: "No Franchise Markup", desc: "Big shutter brands carry showroom overhead and franchise fees. We don't. Typically 20–30% less for the same materials." },
  { title: "Fast Quote, Fast Install", desc: "Free quote in 24 hours. Most plantation installs complete in 1–2 visits. Hurricane shutters before storm season — call us early." },
  { title: "Custom Sizing Welcome", desc: "Arched, bay, oversized, or non-standard openings — we handle the measurements and source the right panels." },
  { title: "Fully Insured", desc: "Full liability coverage on every install. Your home is protected, and so are we." },
];

const processSteps = [
  { title: "Tell Us What You Need", description: "Call, text, or fill out our form. Interior plantation, exterior curb appeal, hurricane prep? Send a photo of the window — saves the first visit." },
  { title: "Measure & Quote", description: "We come out, measure every opening, walk options (material, color, mount style), and give you an upfront quote — no high-pressure consult." },
  { title: "We Install It", description: "Panels arrive, we install clean and level, clean up, and walk you through care. Most jobs done in 1–2 visits." },
];

const faqs = [
  { q: "How long does plantation shutter installation take?", a: "Most homes are 1–2 visits: one to measure, one to install once panels arrive (typically 2–4 weeks lead time from order). Same-day install possible when stock sizes fit your windows." },
  { q: "Can you do arched, bay, or oversized windows?", a: "Yes. Custom-size plantation shutters are one of our specialties — most franchise installers quote 6+ weeks for custom; we typically deliver in 2–4 weeks because we source direct, not through a showroom." },
  { q: "Real wood vs faux wood vs vinyl — which is right?", a: "Depends on the room. Real wood for studies and formal rooms (premium look, stainable). Faux wood for kitchens and bathrooms (humidity-resistant, looks like wood). Vinyl for budget-friendly or rental units. We walk you through trade-offs on the visit — no upsell pressure." },
  { q: "Can you install hurricane shutters before storm season?", a: "Yes — and it's the #1 reason to call us by early summer. Aluminum panel, accordion, and Bahama styles available. Installed and labeled per opening so they're ready to deploy when a storm is named." },
  { q: "How fast can I get a quote?", a: "Same-day call back, free in-home quote within 24–48 hours for Charlotte, Ballantyne, Matthews, Concord, and surrounding metro. No $99 consult fee like the franchise brands charge." },
  { q: "Do you also repair existing shutters?", a: "Yes — broken louvers, snapped tilt rods, sagging hinges, cracked exterior vinyl, hurricane hardware kits. If repair makes sense over replacement, we'll tell you straight." },
];
---

<LandingLayout title={seo.title} description={seo.description} canonical="/lp/shutter-installation">

  <!-- Hero -->
  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="Shutter installation specialist in Charlotte" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/80 to-neutral-900/40"></div>
    </div>
    <div class="container relative z-10">
      <div class="py-12 lg:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <div class="order-1 lg:order-1">
            <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">Charlotte's Local Shutter Installer</span>
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4 leading-tight">
              Shutter Installation <span class="text-primary-500">Charlotte NC</span> — Custom Fit, Local Crew, Fair Price.
            </h1>
            <p class="text-lg text-neutral-200 mb-6 max-w-xl">
              Plantation shutters, exterior vinyl, hurricane panels, custom-size and arched windows — <strong class="text-white">measured, supplied, and installed by a local Charlotte team.</strong> No franchise markup, no high-pressure showroom call.
            </p>

            <div class="grid grid-cols-3 gap-4 mb-8">
              <div class="bg-white/5 rounded-lg p-4 text-center">
                <p class="text-3xl font-heading font-bold text-primary-500">500+</p>
                <p class="text-white/80 text-sm">Projects Done</p>
              </div>
              <div class="bg-white/5 rounded-lg p-4 text-center">
                <p class="text-3xl font-heading font-bold text-primary-500">5.0</p>
                <p class="text-white/80 text-sm">Google Rating</p>
              </div>
              <div class="bg-white/5 rounded-lg p-4 text-center">
                <p class="text-3xl font-heading font-bold text-primary-500">Insured</p>
                <p class="text-white/80 text-sm">Fully Covered</p>
              </div>
            </div>

            <a href="tel:+19803916833" class="inline-flex items-center gap-3 text-white hover:text-primary-400 transition-colors">
              <div class="w-12 h-12 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-6 h-6 text-neutral-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <p class="text-sm text-neutral-300">Call us now</p>
                <p class="text-xl font-heading font-bold">(980) 391-6833</p>
              </div>
            </a>
            <p class="text-sm text-neutral-300 mt-2">After hours? Leave a voicemail or chat with our virtual assistant — we respond fast.</p>
          </div>
          <div class="order-2 lg:order-2">
            <LandingForm formId="lp-shutter-installation-hero" formName="Landing Page - Shutter Installation" servicePreselect="shutter-installation" ctaText="Get Free Quote" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <!-- Problem / Solution -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block px-4 py-2 bg-red-100 text-red-700 text-sm font-bold rounded-full mb-4">Sound Familiar?</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">The Shutter Quote Runaround</h2>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex gap-3"><span class="text-red-500">✗</span> Franchise quoted $4,500–$5,000 and pushed a 90-minute showroom call</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Custom arched window? "6 weeks lead time and double the price"</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Hurricane shutters needed before storm season — nobody can install in time</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Old exterior vinyl shutters are falling off — installers only want full replacements</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> "20% off NEW" gimmick that's already priced into the markup</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Salesperson measures, but a different crew installs — handoff problems</li>
          </ul>
        </div>
        <div>
          <span class="inline-block px-4 py-2 bg-green-100 text-green-700 text-sm font-bold rounded-full mb-4">The Local Way</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Local Install. Custom Fit. Fair Price.</h2>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Plantation, exterior vinyl, hurricane, custom-size — <strong>one local team handles all of it</strong></li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Same person measures, quotes, and installs — no handoffs</li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> <strong>Typically 20–30% less</strong> than franchise quotes for the same materials</li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Free quote in 24h, no $99 consult fee</li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Hurricane shutters installed in 48h when storm season is coming</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section-alt">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Every Shutter Type We Install</h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">Interior plantation, exterior curb-appeal, hurricane protection, custom sizes — one call covers it all.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {services.map((service) => (
          <div class="card group overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" width="400" height="300" />
            </div>
            <div class="p-6">
              <h3 class="font-heading font-bold text-neutral-900 mb-2 flex items-center gap-2"><span class="text-xl">{service.icon}</span> {service.title}</h3>
              <p class="text-sm text-neutral-600">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ScrollGallery title="Recent Shutter Installations" serviceSlug="shutter-installation" />

  <!-- CTA Banner -->
  <section class="py-10 md:py-14 bg-gradient-to-r from-primary-600 to-primary-500">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
        <div class="text-center lg:text-left max-w-2xl">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-2">Local Install. 20–30% Less Than Franchise Quotes.</h2>
          <p class="text-lg text-primary-100">Free quote in 24 hours. No $99 consult fee.</p>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a href="#lp-shutter-installation-hero" class="btn px-8 py-4 text-lg font-bold rounded-lg bg-neutral-900 text-white hover:bg-neutral-800">Get Free Quote</a>
          <a href="tel:+19803916833" class="flex items-center gap-2 font-bold text-white hover:text-white/80"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg><span class="underline">(980) 391-6833</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section">
    <div class="container">
      <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 text-center mb-10">Why Charlotte Homeowners Choose iFIXX for Shutters</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {whyChooseUs.map((item) => (
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-secondary-50 flex items-center justify-center">
              <svg class="w-6 h-6 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            </div>
            <div>
              <h3 class="text-lg font-heading font-semibold text-neutral-900 mb-1">{item.title}</h3>
              <p class="text-neutral-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">How It Works</h2>
        <p class="text-neutral-600">Three simple steps from quote to installed.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {processSteps.map((step, index) => (
          <div class="text-center relative">
            {index < processSteps.length - 1 && (<div class="hidden md:block absolute top-8 left-1/2 w-full h-0.5 bg-primary-200"></div>)}
            <div class="relative"><div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center shadow-lg"><span class="text-2xl font-heading font-bold text-neutral-900">{index + 1}</span></div></div>
            <h3 class="text-lg font-heading font-semibold text-neutral-900 mb-2">{step.title}</h3>
            <p class="text-neutral-600 text-sm">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <GoogleReviews title="What Charlotte Homeowners Say" />

  <!-- About -->
  <section class="section section-alt">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img src="/images/ui/team.webp" alt="iFIXX team — Jaime & Hamed" class="w-full h-auto object-cover aspect-[4/3]" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -right-4 bg-white rounded-xl shadow-xl p-4 hidden lg:block">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-5 h-5 text-neutral-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div>
                <p class="font-heading font-bold text-neutral-900 text-sm">500+ Projects</p>
                <p class="text-xs text-neutral-600">Completed in Charlotte</p>
              </div>
            </div>
          </div>
        </div>
        <div>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Not a Franchise. Your Neighbors.</h2>
          <p class="text-neutral-600 mb-4">We're Jaime and Hamed — a Charlotte family that's been improving homes for over 5 years. Shutter installs are one of our favorite jobs because we get to deliver real value: same materials as the big brands, custom-sized to your home, installed by the same people who quoted you — at a fair price.</p>
          <p class="text-neutral-600 mb-4">Our promise is simple: <strong>answer the phone, show up on time, install quality work, and charge a fair price.</strong> That's it. That's the whole business model.</p>
          <p class="text-neutral-600">We live in Charlotte, we work in Charlotte, and we've built our reputation one project at a time — 500+ and counting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <details class="group bg-white rounded-xl shadow-sm border border-neutral-100" open={index === 0}>
              <summary class="flex items-center justify-between cursor-pointer list-none p-6">
                <span class="font-semibold text-neutral-900 pr-4">{faq.q}</span>
                <svg class="w-5 h-5 text-primary-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="section section-alt">
    <div class="container">
      <div class="text-center mb-10">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-3">Areas We Serve</h2>
        <p class="text-neutral-600">Proudly serving homeowners across the Charlotte metro area.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        {["Charlotte", "Ballantyne", "Matthews", "Concord", "Mint Hill", "Pineville", "Rock Hill", "Waxhaw"].map((city) => (
          <div class="p-4 bg-white rounded-xl border border-neutral-200 text-center">
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <span class="font-medium text-neutral-900">{city}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section bg-neutral-900">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
        <div class="text-center lg:text-left">
          <h2 class="text-3xl lg:text-4xl font-heading font-bold text-white mb-4">Get Your Shutters Installed Right</h2>
          <p class="text-lg text-white/80 mb-6">Free quote in 24h. Local crew. Fair price. No franchise markup.</p>
          <a href="tel:+19803916833" class="btn btn-emergency text-xl px-10 py-5 inline-flex">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (980) 391-6833
          </a>
          <p class="text-sm text-neutral-300 mt-3">After hours? Leave a message or chat with our virtual assistant.</p>
        </div>
        <div>
          <LandingForm formId="lp-shutter-installation-bottom" formName="Landing Page - Shutter Installation (Bottom)" servicePreselect="shutter-installation" ctaText="Get Free Quote" />
        </div>
      </div>
    </div>
  </section>

</LandingLayout>
