---
import LandingLayout from '../../layouts/LandingLayout.astro';
import LandingForm from '../../components/forms/LandingForm.astro';
import TrustBar from '../../components/sections/TrustBar.astro';
import ScrollGallery from '../../components/sections/ScrollGallery.astro';
import GoogleReviews from '../../components/sections/GoogleReviews.astro';

// NOTE: Hero & service card images marked TODO-MUSE use temporary placeholders.
// Muse swap pending — see clients/ifixx/iFIXX-MASTER-PLAN-V3-2026-05-11.md (Photo Brief, Landing #1).
const heroImage = "/images/projects/construction-wood-framing-window.webp"; // TODO-MUSE: window-screen-rescreen-frame-repair-hero.webp

const seo = {
  title: "Window Repair Charlotte NC | Stuck, Drafty, Broken Windows Fixed | iFIXX",
  description: "Window repair Charlotte NC — stuck sashes, foggy panes, broken balancers, torn screens. Family-owned, insured, same-day available. Call (980) 391-6833."
};

const services = [
  { icon: "🪟", title: "Stuck or Won't-Close Window Repair", desc: "Sash that won't lift, jammed tracks, painted-shut windows — back to smooth operation.", image: "/images/projects/construction-wood-framing-window.webp" }, // TODO-MUSE: window-trim-sash-wood-repair-painted-white.webp
  { icon: "🌬️", title: "Drafty Window & Weatherstrip Fix", desc: "Feel cold air through the frame? Reseal, re-weatherstrip, and re-caulk for tight windows.", image: "/images/projects/door-window-repair-oscillating-tool-trim-work.webp" }, // TODO-MUSE: window-screen-frame-bent-repair-aluminum.webp
  { icon: "⚙️", title: "Window Balancer & Sash Cord", desc: "Snapped balancer? Sash falls down? We replace the spring or cord so it stays where you put it.", image: "/images/projects/door-window-blinds-installation-leveling.webp" }, // TODO-MUSE: storm-window-aluminum-latch-repair-charlotte-home.webp
  { icon: "🌫️", title: "Foggy or Broken Glass Pane", desc: "Cracked single-pane, failed-seal double-pane, foggy IGUs — residential glass replaced.", image: "/images/projects/construction-wood-framing-window.webp" }, // TODO-MUSE: window-pane-glass-replacement-broken-residential.webp
  { icon: "🪵", title: "Frame & Trim Rot Repair", desc: "Soft wood, rotted sills, peeling exterior trim — cut out, rebuild, paint to match.", image: "/images/projects/door-window-repair-oscillating-tool-trim-work.webp" }, // TODO-MUSE: window-screen-replacement-pet-resistant-mesh.webp
  { icon: "🪟", title: "Screen Repair & Rescreen", desc: "Torn, popped-out, or pet-damaged screens. Standard and pet-resistant mesh available.", image: "/images/projects/door-window-blinds-installation-leveling.webp" }, // TODO-MUSE: window-screen-rescreen-mesh-spline-roller.webp
];

const whyChooseUs = [
  { title: "Talk to the Owners", desc: "When you call, Jaime or Hamed answer. No dispatchers, no call centers, no runaround." },
  { title: "Upfront Pricing", desc: "We tell you the price before we start. No surprises, no awkward conversations at the end." },
  { title: "Same-Day Available", desc: "Need it done today? We'll do our best to get there same-day for urgent jobs." },
  { title: "Repair Specialists, Not Replacers", desc: "Big window companies push full replacement. We fix what can be fixed — saves you thousands when you don't need new windows." },
  { title: "We Make It Right", desc: "If something's not perfect, we fix it. That's not a policy — that's just how we work." },
  { title: "Fully Insured", desc: "Full liability coverage on every project. Your home is protected, and so are we." },
];

const processSteps = [
  { title: "Tell Us What's Wrong", description: "Call, text, or fill out our form. Stuck window? Foggy glass? Send a photo or video if you can — saves the diagnostic visit." },
  { title: "Get a Free Estimate", description: "We assess size, frame condition, and mesh type — transparent quote before starting." },
  { title: "We Fix It", description: "Most window repairs done in one visit. Clean up after. Window that opens, closes, and locks the way it should." },
];

const faqs = [
  { q: "Why won't my window open or close anymore?", a: "Usually one of three things: a broken balancer or sash cord (spring snapped, sash falls), paint sealing the sash shut, or warped/swollen wood from moisture. All three are fixable without replacing the whole window — we diagnose and tell you which it is." },
  { q: "Can you fix foggy or broken double-pane glass?", a: "Yes. Foggy double-pane means the seal between the two panes failed — we replace the insulated glass unit (IGU) inside the existing frame. Cracked single-pane and standard residential double-pane both replaceable. Custom shapes or large commercial panes we'll refer to a glass specialist." },
  { q: "Do you replace whole windows or just repair them?", a: "We're repair specialists first. Most homeowners think they need new windows when really they need a balancer, weatherstrip, or pane swap — saves thousands. If repair isn't worth it (full frame rot, failed multiple panes), we'll say so honestly and refer you to a replacement contractor we trust." },
  { q: "My window won't lock — can you fix that?", a: "Yes, and it's a security priority. Usually a worn or broken sash lock, misaligned strike plate, or sash that's dropped out of alignment. Most window-lock fixes are same-visit, often under $150." },
  { q: "How fast can you come out for a window repair?", a: "Same-day available for urgent jobs in Charlotte, Ballantyne, Matthews, Concord, and surrounding areas. Call before 10am for best chance. After-hours? Leave a voicemail or chat with our virtual assistant — we respond first thing." },
  { q: "Are you insured?", a: "Yes, fully insured. We can send proof of insurance on request — homeowners and property managers ask all the time, no problem." },
];
---

<LandingLayout title={seo.title} description={seo.description} canonical="/lp/window-screen-repair">

  <!-- Hero -->
  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="Window screen repair specialist in Charlotte" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/80 to-neutral-900/40"></div>
    </div>
    <div class="container relative z-10">
      <div class="py-12 lg:py-20">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <div class="order-1 lg:order-1">
            <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">Charlotte's Window Repair Specialists</span>
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4 leading-tight">
              Window Repair <span class="text-primary-500">Charlotte NC</span> — Stuck, Drafty, Broken? We Fix It.
            </h1>
            <p class="text-lg text-neutral-200 mb-6 max-w-xl">
              Windows that won't open, drafty frames, foggy double-panes, broken balancers, torn screens — <strong class="text-white">one team fixes all of it.</strong> Family-owned, insured, 500+ projects across Charlotte, Ballantyne, Matthews & Concord.
            </p>

            <div class="grid grid-cols-3 gap-4 mb-8">
              <div class="bg-white/5 rounded-lg p-4 text-center">
                <p class="text-3xl font-heading font-bold text-primary-500">500+</p>
                <p class="text-white/80 text-sm">Projects Done</p>
              </div>
              <div class="bg-white/5 rounded-lg p-4 text-center">
                <p class="text-3xl font-heading font-bold text-primary-500">5.0</p>
                <p class="text-white/80 text-sm">Google Rating</p>
              </div>
              <div class="bg-white/5 rounded-lg p-4 text-center">
                <p class="text-3xl font-heading font-bold text-primary-500">Insured</p>
                <p class="text-white/80 text-sm">Fully Covered</p>
              </div>
            </div>

            <a href="tel:+19803916833" class="inline-flex items-center gap-3 text-white hover:text-primary-400 transition-colors">
              <div class="w-12 h-12 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-6 h-6 text-neutral-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              </div>
              <div>
                <p class="text-sm text-neutral-300">Call us now</p>
                <p class="text-xl font-heading font-bold">(980) 391-6833</p>
              </div>
            </a>
            <p class="text-sm text-neutral-300 mt-2">After hours? Leave a voicemail or chat with our virtual assistant — we respond fast.</p>
          </div>
          <div class="order-2 lg:order-2">
            <LandingForm formId="lp-window-screen-hero" formName="Landing Page - Window Screen Repair" servicePreselect="window-screen-repair" ctaText="Get Free Estimate" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <!-- Problem / Solution -->
  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-block px-4 py-2 bg-red-100 text-red-700 text-sm font-bold rounded-full mb-4">Sound Familiar?</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Living With Broken Windows</h2>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex gap-3"><span class="text-red-500">✗</span> The window that won't open since last winter</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Cold drafts you can feel through the frame</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> Foggy double-pane you've ignored for years</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> A balancer that snapped — sash falls every time</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> A window that won't lock — security concern</li>
            <li class="flex gap-3"><span class="text-red-500">✗</span> A torn screen letting bugs in</li>
          </ul>
        </div>
        <div>
          <span class="inline-block px-4 py-2 bg-green-100 text-green-700 text-sm font-bold rounded-full mb-4">The Fix</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Repair First. Replace Only When We Have To.</h2>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Stuck sashes, balancers, weatherstrip, glass, frames, screens — <strong>one team handles all of it</strong></li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Talk to the owners, not a dispatcher</li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Honest repair-vs-replace advice — <strong>we'll save you thousands when replacement isn't needed</strong></li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Same-day for most jobs in Charlotte metro</li>
            <li class="flex gap-3"><span class="text-green-500 font-bold">✓</span> Insured, upfront priced, 500+ projects done</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="section section-alt">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Every Window Problem We Fix</h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">From a stuck sash to a foggy double-pane to a torn screen — one call covers it all.</p>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {services.map((service) => (
          <div class="card group overflow-hidden">
            <div class="aspect-[4/3] overflow-hidden">
              <img src={service.image} alt={service.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" decoding="async" width="400" height="300" />
            </div>
            <div class="p-6">
              <h3 class="font-heading font-bold text-neutral-900 mb-2 flex items-center gap-2"><span class="text-xl">{service.icon}</span> {service.title}</h3>
              <p class="text-sm text-neutral-600">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <ScrollGallery title="Recent Window Repair Projects" serviceSlug="general-repairs" />

  <!-- CTA Banner -->
  <section class="py-10 md:py-14 bg-gradient-to-r from-primary-600 to-primary-500">
    <div class="container">
      <div class="flex flex-col lg:flex-row items-center justify-between gap-6">
        <div class="text-center lg:text-left max-w-2xl">
          <h2 class="text-2xl md:text-3xl font-heading font-bold text-white mb-2">Stop Living With Broken Windows</h2>
          <p class="text-lg text-primary-100">Free estimate, same-day available, no obligation.</p>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-4">
          <a href="#lp-window-screen-hero" class="btn px-8 py-4 text-lg font-bold rounded-lg bg-neutral-900 text-white hover:bg-neutral-800">Get Free Estimate</a>
          <a href="tel:+19803916833" class="flex items-center gap-2 font-bold text-white hover:text-white/80"><svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg><span class="underline">(980) 391-6833</span></a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="section">
    <div class="container">
      <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 text-center mb-10">Why Charlotte Homeowners Choose iFIXX for Window Repair</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
        {whyChooseUs.map((item) => (
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-secondary-50 flex items-center justify-center">
              <svg class="w-6 h-6 text-secondary-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
            </div>
            <div>
              <h3 class="text-lg font-heading font-semibold text-neutral-900 mb-1">{item.title}</h3>
              <p class="text-neutral-600 text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">How It Works</h2>
        <p class="text-neutral-600">Three simple steps to windows that work right.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        {processSteps.map((step, index) => (
          <div class="text-center relative">
            {index < processSteps.length - 1 && (<div class="hidden md:block absolute top-8 left-1/2 w-full h-0.5 bg-primary-200"></div>)}
            <div class="relative"><div class="w-16 h-16 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center shadow-lg"><span class="text-2xl font-heading font-bold text-neutral-900">{index + 1}</span></div></div>
            <h3 class="text-lg font-heading font-semibold text-neutral-900 mb-2">{step.title}</h3>
            <p class="text-neutral-600 text-sm">{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <GoogleReviews title="What Charlotte Homeowners Say" />

  <!-- About -->
  <section class="section section-alt">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
        <div class="relative">
          <div class="rounded-2xl overflow-hidden shadow-2xl">
            <img src="/images/ui/team.webp" alt="iFIXX team — Jaime & Hamed" class="w-full h-auto object-cover aspect-[4/3]" loading="lazy" decoding="async" />
          </div>
          <div class="absolute -bottom-4 -right-4 bg-white rounded-xl shadow-xl p-4 hidden lg:block">
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-primary-500 flex items-center justify-center">
                <svg class="w-5 h-5 text-neutral-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              </div>
              <div>
                <p class="font-heading font-bold text-neutral-900 text-sm">500+ Projects</p>
                <p class="text-xs text-neutral-600">Completed in Charlotte</p>
              </div>
            </div>
          </div>
        </div>
        <div>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Not a Franchise. Your Neighbors.</h2>
          <p class="text-neutral-600 mb-4">We're Jaime and Hamed — a Charlotte family that's been fixing homes for over 5 years. Window repair is one of our favorite jobs because the big companies push full replacement when most windows just need a balancer, a weatherstrip, or a pane swap. We'll tell you the truth, then do the work.</p>
          <p class="text-neutral-600 mb-4">Our promise is simple: <strong>answer the phone, show up on time, do quality work, and charge a fair price.</strong> That's it. That's the whole business model.</p>
          <p class="text-neutral-600">We live in Charlotte, we work in Charlotte, and we've built our reputation one project at a time — 500+ and counting.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQs -->
  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">Frequently Asked Questions</h2>
        <div class="space-y-4">
          {faqs.map((faq, index) => (
            <details class="group bg-white rounded-xl shadow-sm border border-neutral-100" open={index === 0}>
              <summary class="flex items-center justify-between cursor-pointer list-none p-6">
                <span class="font-semibold text-neutral-900 pr-4">{faq.q}</span>
                <svg class="w-5 h-5 text-primary-500 group-open:rotate-180 transition-transform flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
              </summary>
              <div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Service Areas -->
  <section class="section section-alt">
    <div class="container">
      <div class="text-center mb-10">
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-3">Areas We Serve</h2>
        <p class="text-neutral-600">Proudly serving homeowners across the Charlotte metro area.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 max-w-3xl mx-auto">
        {["Charlotte", "Ballantyne", "Matthews", "Concord", "Mint Hill", "Pineville", "Rock Hill", "Waxhaw"].map((city) => (
          <div class="p-4 bg-white rounded-xl border border-neutral-200 text-center">
            <div class="flex items-center justify-center gap-2">
              <svg class="w-4 h-4 text-primary-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <span class="font-medium text-neutral-900">{city}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section bg-neutral-900">
    <div class="container">
      <div class="grid lg:grid-cols-2 gap-12 items-center max-w-5xl mx-auto">
        <div class="text-center lg:text-left">
          <h2 class="text-3xl lg:text-4xl font-heading font-bold text-white mb-4">Get Your Windows Working Right</h2>
          <p class="text-lg text-white/80 mb-6">Free estimate, honest repair-vs-replace advice, no obligation.</p>
          <a href="tel:+19803916833" class="btn btn-emergency text-xl px-10 py-5 inline-flex">
            <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (980) 391-6833
          </a>
          <p class="text-sm text-neutral-300 mt-3">After hours? Leave a message or chat with our virtual assistant.</p>
        </div>
        <div>
          <LandingForm formId="lp-window-screen-bottom" formName="Landing Page - Window Screen (Bottom)" servicePreselect="window-screen-repair" ctaText="Get Free Estimate" />
        </div>
      </div>
    </div>
  </section>

</LandingLayout>
