---
// IMAGES: shared with the fence-installation landing. Hero + support are REAL iFIXX
// vinyl fence project photos (enhanced). Wood and aluminum tiles are AI variations
// generated from the real vinyl project photos; swap for real repair photos when available.
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import GoogleReviews from '../components/sections/GoogleReviews.astro';
import CTASection from '../components/sections/CTASection.astro';
import LandingEstimateForm from '../components/forms/LandingEstimateForm.astro';
import ProjectMarquee from '../components/sections/ProjectMarquee.astro';

const title = 'Fence Repair in South Charlotte | Leaning Posts, Gates, Storm Damage | iFIXX';
const description = 'Fence repair in South Charlotte, Ballantyne, Waxhaw, Indian Land, and Fort Mill. Leaning posts, sagging gates, sections down after a storm, rotted pickets. Honest repair-or-replace guidance from an insured local crew that answers the phone. Free online estimate from iFIXX.';
const canonical = '/fence-repair-south-charlotte';
const heroImage = '/images/projects/fence-wood-privacy-south-charlotte.webp';
const supportImage = '/images/projects/fence-vinyl-install-crew-south-charlotte.webp';
const leadType = 'fence_repair';

const serviceAreas = ['South Charlotte', 'Ballantyne', 'Waxhaw', 'Indian Land', 'Fort Mill', 'Pineville', 'Matthews', 'Weddington'];

const repairItems = [
  'Leaning or wobbly fence posts reset or replaced',
  'Sagging or dragging gates that no longer latch or swing right',
  'Sections down or damaged after a storm',
  'Rotted, broken, or missing pickets and panels replaced',
  'Wood and vinyl privacy fence repairs that match what is already there',
  'Repair first when it makes sense, and an honest replacement price when it does not',
  'Fixes that keep kids and dogs safely inside the yard'
];

const galleryImages = [
  { src: '/images/projects/fence-wood-privacy-south-charlotte.webp', alt: 'Pressure-treated wood privacy fence maintained by iFIXX in South Charlotte' },
  { src: '/images/projects/fence-vinyl-privacy-south-charlotte.webp', alt: 'White vinyl privacy fence in a South Charlotte backyard by iFIXX' },
  { src: '/images/projects/fence-vinyl-install-crew-south-charlotte.webp', alt: 'iFIXX crew working on a vinyl privacy fence in South Charlotte' },
  { src: '/images/projects/fence-aluminum-south-charlotte.webp', alt: 'Black aluminum fence along a South Charlotte yard' }
];

const whoBullets = [
  'A local, family-owned company serving the Charlotte area.',
  'Our own insured, professional crew repairs and installs fences. No subcontractors.',
  'Repair-first: we fix what can be fixed and tell you straight when it is past saving.',
  'Wood, vinyl, and aluminum, from a single leaning post to full sections.',
  'An honest, itemized quote up front, with a free online estimate to start.',
  'We answer, we show up, and we finish the job. 85 five-star reviews.'
];

const processSteps = [
  { title: 'Tell us what is wrong', text: 'A leaning post, a gate that drags, a section down after a storm, or rot spreading through the pickets. Send photos if you have them, and a real person from our team gets back to you.' },
  { title: 'Repair or replace, told straight', text: 'Most fence problems are a focused repair, not a new fence. We look at the damage, tell you honestly which path makes sense, and give you a clear, itemized price up front.' },
  { title: 'We fix it and stand behind it', text: 'Our insured local crew does the repair, matches the existing fence as closely as possible, keeps the site clean, and stands behind the work.' }
];

const faqs = [
  { q: 'Can my fence be repaired, or does it need to be replaced?', a: 'Usually it can be repaired. A leaning post, a sagging gate, or a few sections down after a storm are focused repairs, not a full replacement. The honest answer depends on the condition of the posts and how far rot or damage has spread. If the fence is genuinely at the end of its life, we tell you straight and price a replacement so you can decide with real numbers.' },
  { q: 'How much does fence repair cost?', a: 'It depends on the material and what is damaged: resetting a post, rehanging a gate, or replacing sections are each priced differently. Once we see the damage, usually from photos, we give you a clear, itemized price up front, honest from the start, with no surprise change orders.' },
  { q: 'Can you fix a leaning fence post?', a: 'Yes. Leaning posts are one of the most common fence repairs in the Charlotte area, especially after wet weather. Depending on the condition, the post gets reset, reinforced, or replaced, and the fence line straightened.' },
  { q: 'My gate drags or will not latch. Can that be repaired?', a: 'Almost always. Gates sag over time as hinges loosen and posts shift. We rehang the gate, adjust or replace the hardware, and if the gate post itself has failed, we fix that too, so the gate swings and latches the way it should.' },
  { q: 'A storm knocked down part of my fence. What now?', a: 'Send us photos of the sections that are down and where you are located. Storm damage is usually repairable by replacing the affected sections and checking the neighboring posts. We move fast on repairs that leave a yard open, especially with dogs or kids at home.' },
  { q: 'Do you repair wood, vinyl, and aluminum fences?', a: 'Yes. Wood and vinyl privacy fences are the most common repairs we see in South Charlotte, and we also work on aluminum. We match the existing material and style as closely as possible so the repair does not stand out.' },
  { q: 'Can you estimate a fence repair online?', a: 'Most fence repairs can start with an online estimate request. Clear photos of the damaged posts, gate, or sections, plus the approximate fence length, are usually enough to scope the repair or tell you if an in-person look is needed.' }
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Fence Repair in South Charlotte',
  description,
  serviceType: 'Fence repair',
  url: `https://ifixxnc.com${canonical}`,
  image: `https://ifixxnc.com${heroImage}`,
  provider: { '@id': 'https://ifixxnc.com/#business' },
  areaServed: serviceAreas,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ifixxnc.com/' },
    { '@type': 'ListItem', position: 2, name: 'Fence Repair South Charlotte', item: `https://ifixxnc.com${canonical}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({ '@type': 'Question', name: faq.q, acceptedAnswer: { '@type': 'Answer', text: faq.a } }))
};
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={heroImage}>
  <Fragment slot="schema"><script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} /><script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} /><script type="application/ld+json" set:html={JSON.stringify(faqSchema)} /></Fragment>

  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0"><img src={heroImage} alt="Wood privacy fence repaired by local iFIXX crew in South Charlotte" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" /><div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/85 to-neutral-900/55"></div></div>
    <div class="container relative z-10"><div class="py-10 lg:py-16"><nav class="mb-6"><ol class="flex items-center gap-2 text-sm text-neutral-300"><li><a href="/" class="hover:text-primary-500 transition-colors">Home</a></li><li class="text-neutral-500">/</li><li class="text-white font-medium">Fence Repair South Charlotte</li></ol></nav>
      <div class="grid grid-cols-1 lg:grid-cols-[0.8fr_1.2fr] gap-8 lg:gap-10 items-start">
        <div class="order-1 lg:order-1">
          <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">Repair-first • Honest repair-or-replace advice • Not a franchise</span>
          <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4">Fence Repair in South Charlotte</h1>
          <p class="text-lg text-neutral-200 mb-4 max-w-xl">A leaning post, a gate that drags, or a section down after a storm does not mean you need a whole new fence. Most fence problems are a focused repair, and we tell you straight when they are not.</p>
          <p class="text-neutral-300 mb-6 max-w-xl">iFIXX is a local, family-owned Charlotte company. Our own insured crew repairs wood, vinyl, and aluminum fences across South Charlotte, matches what is already there, and prices it honestly before you commit.</p>
          <div class="flex flex-col sm:flex-row gap-3 mb-3"><a href="#estimate-form" class="btn btn-primary landing-primary-cta" data-lead-type={leadType}>Request a Free Online Estimate</a><a href="tel:+19803916833" class="btn btn-outline-light landing-phone-cta" data-lead-type={leadType}>Call (980) 391-6833</a></div><p class="text-sm text-neutral-300 mb-8">Fence past saving, or want a brand new one? <a href="/fence-installation-south-charlotte" class="text-primary-400 underline underline-offset-2 hover:text-primary-300">See our fence installations</a></p><ProjectMarquee images={galleryImages} title="Our Latest Fence Work in South Charlotte" />
          <div class="grid grid-cols-2 gap-4">{['Repair or replace, told straight', 'Posts, gates, sections', 'Wood, vinyl, aluminum', 'Insured local crew'].map((chip) => (<div class="flex items-center gap-3 text-white"><span class="w-9 h-9 rounded-full bg-primary-500/20 flex items-center justify-center text-primary-400">✓</span><span class="text-sm font-medium">{chip}</span></div>))}</div>
        </div>
        <div id="estimate-form" class="order-2 lg:order-2 scroll-mt-24 min-w-0"><LandingEstimateForm serviceSlug="fence-repair" serviceTitle="Fence Repair" formId="fence-repair-south-charlotte-estimate" leadType="fence_repair" formName="South Charlotte Fence Repair Landing Form" issueLabel="What needs repair?" issueOptions={['leaning or broken post', 'sagging or dragging gate', 'fence down after a storm', 'rotted or broken pickets', 'repair vs replace advice', 'replace the whole fence', 'other']} descriptionPlaceholder="Briefly describe what is wrong with the fence and where you are located (photos help)." photoLabel="Upload photos of the damage if you have them" submitLabel="Request a Free Online Estimate" /></div>
      </div>
    </div></div>
  </section>

  <TrustBar variant="light" />

  <section class="section"><div class="container"><div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center"><div><span class="badge mb-4">The pain: the fence keeps getting worse</span><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-6">A small fence problem becomes a big one if it sits too long</h2><p class="text-neutral-600 mb-5">A leaning post pulls the sections around it out of line. A dragging gate chews up its hinges. One section down after a storm leaves the whole yard open for dogs and kids. Most homeowners wait because they are afraid the answer is “replace the whole fence.” Usually, it is not.</p><p class="text-neutral-600 mb-8">We are repair-first: we fix what can reasonably be fixed, match the existing fence as closely as possible, and tell you straight when a run is genuinely past saving, with an honest price either way. Your call, with real numbers in front of you.</p><ul class="space-y-4">{repairItems.map((item) => (<li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>))}</ul></div><div class="rounded-2xl overflow-hidden shadow-2xl"><img src={supportImage} alt="iFIXX crew working on a vinyl privacy fence in South Charlotte" class="w-full aspect-[4/3] object-cover" width="700" height="525" loading="lazy" decoding="async" /></div></div></div></section>

  <section class="section section-alt"><div class="container"><div class="max-w-3xl mx-auto text-center mb-12"><span class="badge mb-4">Recent fence work</span><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Posts, gates, pickets, and storm-damage repairs</h2><p class="text-neutral-600">Use the gallery as a guide for the kinds of fence repairs we can discuss from photos: post resets, gate rehangs, section replacements, and picket or panel repairs in wood, vinyl, and aluminum.</p></div><div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">{galleryImages.map((image) => (<figure class="group overflow-hidden rounded-2xl bg-white shadow-sm border border-neutral-200"><img src={image.src} alt={image.alt} class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-300" width="520" height="390" loading="lazy" decoding="async" /></figure>))}</div></div></section>

  <section class="section"><div class="container"><div class="max-w-3xl mx-auto text-center mb-12"><span class="badge mb-4">Simple local process</span><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Repair it before it takes the rest of the fence with it</h2><p class="text-neutral-600">You do not need to diagnose the fence yourself. Tell us what you are seeing, send photos if you have them, and our local team will help identify the next practical step.</p></div><div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">{processSteps.map((step, index) => (<div class="card p-6 text-center"><div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center font-heading font-bold text-neutral-900 text-xl">{index + 1}</div><h3 class="font-heading font-bold text-neutral-900 mb-2">{step.title}</h3><p class="text-sm text-neutral-600">{step.text}</p></div>))}</div></div></section>

  <section class="section section-alt"><div class="container"><div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto"><div class="bg-white rounded-2xl p-8 shadow-sm border border-neutral-200"><h2 class="text-2xl font-heading font-bold text-neutral-900 mb-4">Who is iFIXX?</h2><img src="/images/ui/team.webp" alt="Jaime Aguilar, owner of iFIXX, with his team" class="w-full aspect-[16/9] object-cover rounded-xl mb-4" width="640" height="360" loading="lazy" decoding="async" /><p class="text-neutral-600 mb-4">Meet Jaime Aguilar, the owner. iFIXX is not a franchise or a call center: it is a local Charlotte family company, and the person responsible for your repair is the same person who answers your call.</p><ul class="space-y-3">{whoBullets.map((item) => (<li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>))}</ul></div><div class="bg-neutral-900 rounded-2xl p-8 text-white shadow-xl"><h2 class="text-2xl font-heading font-bold mb-4">South Charlotte service areas</h2><div class="flex flex-wrap gap-2">{serviceAreas.map((area) => (<span class="px-3 py-2 rounded-full bg-white/10 text-sm">{area}</span>))}</div><p class="text-neutral-300 mt-5">If you are nearby but not listed, send the request and we will confirm availability.</p></div></div></div></section>

  <section class="section"><div class="container"><div class="max-w-4xl mx-auto rounded-2xl bg-neutral-900 text-white p-8 lg:p-10 shadow-xl"><div class="grid grid-cols-1 lg:grid-cols-[1fr_auto] gap-6 items-center"><div><span class="inline-block px-3 py-1 rounded-full bg-primary-500/20 text-primary-400 text-xs font-bold uppercase tracking-wide mb-3">Fence past saving?</span><h2 class="text-2xl lg:text-3xl font-heading font-bold mb-3">We install new fences too, not just repairs</h2><p class="text-neutral-300 max-w-xl">If the posts are gone or you are ready for a new privacy fence, we install wood, vinyl, and aluminum fences across South Charlotte. Honest, itemized pricing, milestone payments, and the same insured local crew.</p></div><a href="/fence-installation-south-charlotte" class="btn btn-primary whitespace-nowrap">See fence installations →</a></div></div></div></section>

  <section class="section"><div class="container"><div class="max-w-3xl mx-auto"><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">Fence Repair FAQs</h2><div class="space-y-4">{faqs.map((faq, index) => (<details class="group bg-white rounded-xl shadow-sm" open={index === 0}><summary class="flex items-center justify-between cursor-pointer list-none p-6"><span class="font-semibold text-neutral-900 pr-4">{faq.q}</span><span class="text-primary-600 group-open:rotate-180 transition-transform">⌄</span></summary><div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div></details>))}</div></div></div></section>

  <GoogleReviews title="What Charlotte Homeowners Say" />
  <CTASection headline="Repair it now, or replace it right. Let's figure out which." subtext="Request a free online estimate for leaning posts, sagging gates, storm damage, or rotted pickets across South Charlotte, Ballantyne, Waxhaw, Indian Land, and Fort Mill." />

  <script is:inline>
    document.addEventListener('click', (event) => {
      const cta = event.target.closest('.landing-primary-cta');
      const phone = event.target.closest('.landing-phone-cta');
      if (!cta && !phone) return;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: cta ? 'landing_cta_click' : 'phone_click', lead_type: 'fence_repair', campaign_test: 'ifixx_south_charlotte_service_test_2026_07', form_location: window.location.pathname });
    });
  </script>
</BaseLayout>
