---
// IMAGES: hero + support are REAL iFIXX vinyl fence project photos (enhanced: cleaned up
// and relit). Wood and aluminum gallery tiles are AI variations generated from the real
// vinyl project photos; swap for real wood/aluminum project photos when available.
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import GoogleReviews from '../components/sections/GoogleReviews.astro';
import CTASection from '../components/sections/CTASection.astro';
import LandingEstimateForm from '../components/forms/LandingEstimateForm.astro';
import ProjectMarquee from '../components/sections/ProjectMarquee.astro';

const title = 'Fence Installation and Repair in South Charlotte | Wood, Vinyl, Aluminum | iFIXX';
const description = 'Privacy fences, replacements, and repairs in South Charlotte, Ballantyne, Waxhaw, Indian Land, and Fort Mill. Wood, vinyl, and aluminum fencing installed by an insured local crew that answers the phone and shows up. Clear, honest pricing from the start. Request a free fence estimate from iFIXX.';
const canonical = '/fence-installation-south-charlotte';
const heroImage = '/images/projects/fence-vinyl-privacy-south-charlotte.webp';
const supportImage = '/images/projects/fence-vinyl-install-crew-south-charlotte.webp';
const leadType = 'fence_install';

const serviceAreas = ['South Charlotte', 'Ballantyne', 'Waxhaw', 'Indian Land', 'Fort Mill', 'Pineville', 'Matthews', 'Weddington'];

const serviceItems = [
  'Privacy fences that give you a backyard you actually want to use',
  'Wood, vinyl, and aluminum fencing installed by our own insured crew',
  'New fence installs and full replacements of an old or failing fence',
  'Fence repairs: leaning posts, sagging or dragging gates, sections down after a storm',
  'Gates that latch and swing the way they should',
  'Straight runs that follow your property line, even on a slope',
  'Clear, itemized pricing and milestone payments, not a big deposit up front'
];

const galleryImages = [
  { src: '/images/projects/fence-vinyl-privacy-south-charlotte.webp', alt: 'White vinyl privacy fence installed in a South Charlotte backyard by iFIXX' },
  { src: '/images/projects/fence-vinyl-install-crew-south-charlotte.webp', alt: 'iFIXX crew installing a white vinyl privacy fence in South Charlotte' },
  { src: '/images/projects/fence-wood-privacy-south-charlotte.webp', alt: 'New pressure-treated wood privacy fence in a South Charlotte backyard' },
  { src: '/images/projects/fence-aluminum-south-charlotte.webp', alt: 'Black aluminum fence along a South Charlotte yard' }
];

const whoBullets = [
  'A local, family-owned company serving the Charlotte area.',
  'Our own insured, professional crew installs and repairs fences. No subcontractors.',
  'Wood, vinyl, and aluminum, for privacy fences, replacements, and repairs.',
  'An honest, itemized quote up front, with a free online estimate to start.',
  'Clear prices and a fast process. We show up and we finish the job.',
  'We build and we repair, from a full new fence to a leaning post or a sagging gate.',
  '85 five-star reviews from Charlotte-area homeowners.'
];

const processSteps = [
  { title: 'Free fence estimate', text: 'Tell us what you need and where you are, and send photos if you have them. A real person from our team gets back to you. No call center and no runaround.' },
  { title: 'Clear, honest price', text: 'We look at the run, the materials, the gates, and any slope or property-line work, then give you a clear, itemized price up front. Honest from the start, with no surprise change orders.' },
  { title: 'We install it, you pay by milestones', text: 'Our insured local crew installs or repairs the fence, keeps the site clean, and stands behind the work. You pay by milestones as the job gets done, not a big deposit up front.' }
];

const faqs = [
  { q: 'How much does a new fence cost?', a: 'It depends on the length of the run, the material (wood, vinyl, or aluminum), the height, the number of gates, and things like slope or old-fence removal. Once we see the project we give you a clear, itemized price up front, honest from the start, with no surprise change orders.' },
  { q: 'Wood, vinyl, or aluminum, which should I choose?', a: 'Wood privacy fencing is the most budget-friendly and gives you full privacy. Vinyl costs more up front but resists rot and needs almost no upkeep. Aluminum is a clean, low-maintenance look that is more about defining the yard than full privacy. We walk you through the trade-offs for your yard and budget.' },
  { q: 'Do you install the fence yourselves?', a: 'Yes. iFIXX is a local, insured Charlotte-area crew and we do the work ourselves. You are not handed off to a call center or a rotating cast of subcontractors.' },
  { q: 'Can you repair my fence instead of replacing it?', a: 'Often, yes. Leaning posts, a sagging or dragging gate, or a few sections down after a storm are usually a focused repair, not a full replacement. If the fence is genuinely at the end of its life we will tell you straight and price a replacement so you can decide.' },
  { q: 'How do you handle payment?', a: 'You pay by milestones as the work gets done, not a big deposit up front. We give you a clear, itemized price before any work starts, and our workmanship is guaranteed.' },
  { q: 'Do I need a permit or HOA approval?', a: 'Many South Charlotte neighborhoods have HOA rules on fence height, material, and setback, and some fences need a permit. We will tell you honestly what your project is likely to require so you can plan for it. We do not promise to handle the paperwork for you, but we build to what your project needs.' },
  { q: 'How long does a fence take to install?', a: 'A straightforward residential run is often a matter of a day or two once materials are in. Longer runs, tricky terrain, and multiple gates take longer. We give you a realistic timeline with your quote.' }
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Fence Installation and Repair in South Charlotte',
  description,
  serviceType: 'Fence installation, replacement, and repair',
  url: `https://ifixxnc.com${canonical}`,
  image: `https://ifixxnc.com${heroImage}`,
  provider: { '@id': 'https://ifixxnc.com/#business' },
  areaServed: serviceAreas,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ifixxnc.com/' },
    { '@type': 'ListItem', position: 2, name: 'Fence Installation South Charlotte', item: `https://ifixxnc.com${canonical}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({ '@type': 'Question', name: faq.q, acceptedAnswer: { '@type': 'Answer', text: faq.a } }))
};
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={heroImage}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="White vinyl privacy fence installed in South Charlotte by iFIXX" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/85 to-neutral-900/55"></div>
    </div>
    <div class="container relative z-10">
      <div class="py-10 lg:py-16">
        <nav class="mb-6"><ol class="flex items-center gap-2 text-sm text-neutral-300"><li><a href="/" class="hover:text-primary-500 transition-colors">Home</a></li><li class="text-neutral-500">/</li><li class="text-white font-medium">Fence Installation South Charlotte</li></ol></nav>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
          <div class="order-1 lg:order-1">
            <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">Privacy and protection • Local, insured crew</span>
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4">Fence Installation and Repair in South Charlotte</h1>
            <p class="text-lg text-neutral-200 mb-4 max-w-xl">iFIXX is a local, family-owned company. Our own insured, professional crew installs and repairs wood, vinyl, and aluminum fences across the Charlotte area, for the privacy and protection your yard needs.</p>
            <p class="text-neutral-300 mb-6 max-w-xl">We install and we repair, we keep the price clear, and we move fast. Start with a free online estimate. Serving South Charlotte, Ballantyne, Waxhaw, Indian Land, Fort Mill, and nearby.</p>
            <div class="flex flex-col sm:flex-row gap-3 mb-8">
              <a href="#estimate-form" class="btn btn-primary landing-primary-cta" data-lead-type={leadType}>Request a Free Fence Estimate</a>
              <a href="tel:+19803916833" class="btn btn-outline-light landing-phone-cta" data-lead-type={leadType}>Call (980) 391-6833</a>
            </div>
            <ProjectMarquee images={galleryImages} label="Real fence projects" />
            <div class="grid grid-cols-2 gap-4">
              {['Family owned and local', 'Wood, vinyl, aluminum', 'Clear prices, fast', 'Insured crew'].map((chip) => (
                <div class="flex items-center gap-3 text-white"><span class="w-9 h-9 rounded-full bg-primary-500/20 flex items-center justify-center text-primary-400">✓</span><span class="text-sm font-medium">{chip}</span></div>
              ))}
            </div>
          </div>
          <div id="estimate-form" class="order-2 lg:order-2 scroll-mt-24 min-w-0">
            <LandingEstimateForm serviceSlug="fence-install" serviceTitle="Fence Installation and Repair" formId="fence-south-charlotte-estimate" leadType="fence_install" formName="South Charlotte Fence Landing Form" issueLabel="What do you need?" issueOptions={['install a new fence', 'replace an old fence', 'privacy fence', 'repair a fence or gate', 'fence down after a storm', 'not sure yet, need advice', 'other']} descriptionPlaceholder="Tell us the approximate length, the material you have in mind, how many gates, and where you are located (photos of the yard help)." photoLabel="Upload photos of the yard or fence if you have them" submitLabel="Request a Free Fence Estimate" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="badge mb-4">Privacy, protection, and a yard you use</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-6">The right fence makes your backyard feel like yours again</h2>
          <p class="text-neutral-600 mb-5">Most people want a fence for a simple reason: privacy and protection. A safe yard for kids and dogs, a clear line with the neighbors, and a backyard you actually want to spend time in. The hard part is finding a crew that answers the phone, shows up, and does it right.</p>
          <p class="text-neutral-600 mb-8">That is where iFIXX fits. We install and repair wood, vinyl, and aluminum fences for South Charlotte homes, price it honestly before you commit, and stand behind the work.</p>
          <ul class="space-y-4">{serviceItems.map((item) => (<li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>))}</ul>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-2xl"><img src={supportImage} alt="iFIXX crew installing a white vinyl privacy fence in South Charlotte" class="w-full aspect-[4/3] object-cover" width="700" height="525" loading="lazy" decoding="async" /></div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="badge mb-4">Recent fence work</span>
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Wood, vinyl, and aluminum fences we install</h2>
        <p class="text-neutral-600">A look at the kind of privacy fences, replacements, and repairs we do for South Charlotte homes.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {galleryImages.map((image) => (<figure class="group overflow-hidden rounded-2xl bg-white shadow-sm border border-neutral-200"><img src={image.src} alt={image.alt} class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-300" width="520" height="390" loading="lazy" decoding="async" /></figure>))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12"><span class="badge mb-4">Simple, honest process</span><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">From estimate to finished fence</h2><p class="text-neutral-600">No pressure and no mystery pricing. Start with a free estimate and we will help you plan a fence that fits your yard and budget.</p></div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">{processSteps.map((step, index) => (<div class="card p-6 text-center"><div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center font-heading font-bold text-neutral-900 text-xl">{index + 1}</div><h3 class="font-heading font-bold text-neutral-900 mb-2">{step.title}</h3><p class="text-sm text-neutral-600">{step.text}</p></div>))}</div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-neutral-200"><h2 class="text-2xl font-heading font-bold text-neutral-900 mb-4">Who is iFIXX?</h2><img src="/images/ui/team.webp" alt="Jaime Aguilar, owner of iFIXX, with his team" class="w-full aspect-[16/9] object-cover rounded-xl mb-4" width="640" height="360" loading="lazy" decoding="async" /><p class="text-neutral-600 mb-4">Meet Jaime Aguilar, the owner. iFIXX is not a franchise or a call center: it is a local Charlotte family company, and the person responsible for your fence is the same person who answers your call.</p><ul class="space-y-3">{whoBullets.map((item) => (<li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>))}</ul></div>
        <div class="bg-neutral-900 rounded-2xl p-8 text-white shadow-xl"><h2 class="text-2xl font-heading font-bold mb-4">South Charlotte service areas</h2><div class="flex flex-wrap gap-2">{serviceAreas.map((area) => (<span class="px-3 py-2 rounded-full bg-white/10 text-sm">{area}</span>))}</div><p class="text-neutral-300 mt-5">If you are nearby but not listed, send the request anyway and we will confirm availability.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container"><div class="max-w-3xl mx-auto"><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">Fence FAQs</h2><div class="space-y-4">{faqs.map((faq, index) => (<details class="group bg-white rounded-xl shadow-sm" open={index === 0}><summary class="flex items-center justify-between cursor-pointer list-none p-6"><span class="font-semibold text-neutral-900 pr-4">{faq.q}</span><span class="text-primary-600 group-open:rotate-180 transition-transform">⌄</span></summary><div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div></details>))}</div></div></div>
  </section>

  <GoogleReviews title="What Charlotte Homeowners Say" />
  <CTASection headline="Ready for a new fence or a fence repair?" subtext="Request a free fence estimate for a privacy fence, replacement, or repair in wood, vinyl, or aluminum across South Charlotte." />

  <script is:inline>
    document.addEventListener('click', (event) => {
      const cta = event.target.closest('.landing-primary-cta');
      const phone = event.target.closest('.landing-phone-cta');
      if (!cta && !phone) return;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: cta ? 'landing_cta_click' : 'phone_click', lead_type: 'fence_install', campaign_test: 'ifixx_south_charlotte_service_test_2026_07', form_location: window.location.pathname });
    });
  </script>
</BaseLayout>
</content>
