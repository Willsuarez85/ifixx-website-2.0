---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import GoogleReviews from '../components/sections/GoogleReviews.astro';
import CTASection from '../components/sections/CTASection.astro';
import LandingEstimateForm from '../components/forms/LandingEstimateForm.astro';
import ProjectMarquee from '../components/sections/ProjectMarquee.astro';

const title = 'Deck Builder in South Charlotte | New Decks & Outdoor Living | iFIXX';
const description = 'Custom decks, rebuilds, and screened porches in South Charlotte, Ballantyne, Waxhaw, Indian Land, and Fort Mill. Wood or composite, built to fit your home and how you use it by an insured local crew. Clear, honest pricing from the start and milestone payments. Request a free deck estimate from iFIXX.';
const canonical = '/deck-builder-south-charlotte';
// Real iFIXX project photos (enhanced): a deck-to-covered-porch build in the Charlotte area.
const heroImage = '/images/projects/deck-covered-porch-south-charlotte.webp';
const supportImage = '/images/projects/deck-wood-railing-south-charlotte.webp';
const leadType = 'deck_build';

const serviceAreas = ['South Charlotte', 'Ballantyne', 'Waxhaw', 'Indian Land', 'Fort Mill', 'Pineville', 'Matthews', 'Weddington'];

const buildItems = [
  'New decks for homes that do not have one yet',
  'Replacing an old, unsafe deck with a bigger, better one',
  'Raised decks, ground-level decks, and multi-level layouts',
  'Wood (pressure-treated) or low-maintenance composite boards',
  'Railings, stairs, built-in benches, and lighting',
  'Screened porches and covered outdoor living spaces',
  'Clear, itemized pricing and milestone payments, not a big deposit up front'
];

const galleryImages = [
  { src: '/images/projects/deck-covered-porch-south-charlotte.webp', alt: 'Covered porch addition built by iFIXX in South Charlotte' },
  { src: '/images/projects/deck-covered-porch-side-south-charlotte.webp', alt: 'Finished covered porch and outdoor living space in South Charlotte' },
  { src: '/images/projects/deck-porch-framing-south-charlotte.webp', alt: 'Covered porch framing built by iFIXX in South Charlotte' },
  { src: '/images/projects/deck-porch-framing-crew-south-charlotte.webp', alt: 'iFIXX crew framing a covered porch in South Charlotte' },
  { src: '/images/projects/deck-porch-install-crew-south-charlotte.webp', alt: 'iFIXX crew building a covered porch in South Charlotte' },
  { src: '/images/projects/deck-wood-railing-south-charlotte.webp', alt: 'Wood deck with railing built by iFIXX in South Charlotte' },
  { src: '/images/projects/deck-wood-exterior-patio.webp', alt: 'Finished wood deck and exterior patio' },
  { src: '/images/projects/outdoor-living-deck-construction-screened-porch.webp', alt: 'New deck build with screened porch' }
];

const whoBullets = [
  'A local, family-owned company. Building decks and porches is what we do.',
  'Over ten years of hands-on experience with decks, rebuilds, and screened porches.',
  'We build and we repair, from a full new deck to a few bad boards or a loose railing.',
  'An honest, itemized quote up front, with a free online estimate to start.',
  'We help you pick the material that lasts and adds value, not the one that pays us most.',
  'Clear prices and a fast process. We show up and we finish the job.',
  'Insured, professional, and local to the Charlotte area. 85 five-star reviews.'
];

const processSteps = [
  { title: 'Free deck estimate', text: 'Tell us the space, how you want to use it, and any photos of the yard. We look at what actually fits your home and budget, with no pressure and no hard sell.' },
  { title: 'Plan, materials, and a clear price', text: 'We help you choose the layout, wood vs composite, railings, and stairs, then give you a clear, itemized price up front. Honest from the start, with no surprise change orders.' },
  { title: 'We build it, you pay by milestones', text: 'Our insured local crew builds the deck, keeps the site clean, and keeps you updated. You pay by milestones as the work gets done, not a big deposit up front. We stay involved from the first call to the final walk-through.' }
];

const faqs = [
  { q: 'How much does it cost to build a new deck?', a: 'It depends on size, height, material, and features like railings, stairs, and lighting. Wood (pressure-treated) is the most budget-friendly and composite costs more up front but needs far less maintenance. Once we see the space we give you a clear, itemized price up front, honest from the start, with no surprise change orders.' },
  { q: 'Wood or composite, which should I choose?', a: 'Wood costs less to build and looks great but needs regular staining and sealing. Composite costs more up front but resists rot, fading, and splinters and needs almost no upkeep. We walk you through the trade-offs for your budget and how long you plan to stay in the home.' },
  { q: 'How do you handle payment?', a: 'You pay by milestones as the work gets done, not a big deposit up front. We give you a clear, itemized price before any work starts, and our workmanship is guaranteed.' },
  { q: 'Do you handle permits?', a: 'New decks in the Charlotte area often require a permit and an inspection. We will tell you honestly what your project needs and help you plan around it so the build is safe and done right.' },
  { q: 'How long does a new deck take to build?', a: 'A straightforward deck is often a matter of days once materials are in and any permit is squared away. Larger or multi-level builds and screened porches take longer. We give you a realistic timeline with your quote.' },
  { q: 'Is the deck built safely and to code?', a: 'Yes. iFIXX is an insured local Charlotte-area team, not a national franchise. For larger structural builds we are upfront about the permits and inspections your project needs and make sure the deck is built safely and to code.' },
  { q: 'I actually just need a repair, can you help?', a: 'Yes. If your current deck mostly needs boards, railings, or steps fixed rather than a full build, start on our deck repair page instead so we can scope it as a repair.' }
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Deck Builder in South Charlotte',
  description,
  serviceType: 'Deck building and outdoor living construction',
  url: `https://ifixxnc.com${canonical}`,
  image: `https://ifixxnc.com${heroImage}`,
  provider: { '@id': 'https://ifixxnc.com/#business' },
  areaServed: serviceAreas,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://ifixxnc.com/' },
    { '@type': 'ListItem', position: 2, name: 'Deck Builder South Charlotte', item: `https://ifixxnc.com${canonical}` }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({ '@type': 'Question', name: faq.q, acceptedAnswer: { '@type': 'Answer', text: faq.a } }))
};
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={heroImage}>
  <Fragment slot="schema">
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <section class="relative bg-neutral-900 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img src={heroImage} alt="New deck and outdoor living space built in South Charlotte by iFIXX" class="w-full h-full object-cover" width="1920" height="1080" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/95 via-neutral-900/85 to-neutral-900/55"></div>
    </div>
    <div class="container relative z-10">
      <div class="py-10 lg:py-16">
        <nav class="mb-6"><ol class="flex items-center gap-2 text-sm text-neutral-300"><li><a href="/" class="hover:text-primary-500 transition-colors">Home</a></li><li class="text-neutral-500">/</li><li class="text-white font-medium">Deck Builder South Charlotte</li></ol></nav>
        <div class="grid grid-cols-1 lg:grid-cols-[0.8fr_1.2fr] gap-8 lg:gap-10 items-start">
          <div class="order-1 lg:order-1">
            <span class="inline-block px-4 py-2 bg-primary-500 text-neutral-900 text-sm font-bold rounded-full mb-4">New decks & outdoor living • Local, insured crew</span>
            <h1 class="text-3xl lg:text-4xl xl:text-5xl font-heading font-bold text-white mb-4">Local Deck Builders in South Charlotte</h1>
            <p class="text-lg text-neutral-200 mb-4 max-w-xl">iFIXX is a local, family-owned company with over ten years building decks, porches, and rebuilds across the Charlotte area. Wood or composite, a brand new deck or a full tear-down and rebuild.</p>
            <p class="text-neutral-300 mb-6 max-w-xl">We build and we repair, we keep the price clear, and we move fast. Start with a free online estimate. Serving South Charlotte, Ballantyne, Waxhaw, Indian Land, Fort Mill, and nearby.</p>
            <div class="flex flex-col sm:flex-row gap-3 mb-3">
              <a href="#estimate-form" class="btn btn-primary landing-primary-cta" data-lead-type={leadType}>Request a Free Deck Estimate</a>
              <a href="tel:+19803916833" class="btn btn-outline-light landing-phone-cta" data-lead-type={leadType}>Call (980) 391-6833</a>
            </div>
            <p class="text-sm text-neutral-300 mb-8">Just need boards, railings, or steps fixed? <a href="/deck-repair-south-charlotte" class="text-primary-400 underline underline-offset-2 hover:text-primary-300">Start on our deck repair page</a></p>
            <ProjectMarquee images={galleryImages} title="Our Latest Deck & Porch Projects in South Charlotte" />
            <div class="grid grid-cols-2 gap-4">
              {['Family owned, 10+ years', 'Build or repair', 'Clear prices, fast', 'Insured local crew'].map((chip) => (
                <div class="flex items-center gap-3 text-white"><span class="w-9 h-9 rounded-full bg-primary-500/20 flex items-center justify-center text-primary-400">✓</span><span class="text-sm font-medium">{chip}</span></div>
              ))}
            </div>
          </div>
          <div id="estimate-form" class="order-2 lg:order-2 scroll-mt-24 min-w-0">
            <LandingEstimateForm serviceSlug="deck-build" serviceTitle="New Deck Build" formId="deck-builder-south-charlotte-estimate" leadType="deck_build" formName="South Charlotte Deck Builder Landing Form" issueLabel="What are you looking to build?" issueOptions={['build a new deck', 'replace an old deck', 'add a screened porch', 'covered or outdoor living space', 'not sure yet, need ideas', 'other']} descriptionPlaceholder="Tell us about the space, how you want to use it, and any budget range or timeline (photos of the yard help)." photoLabel="Upload photos of the space if you have them" submitLabel="Request a Free Deck Estimate" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <TrustBar variant="light" />

  <section class="section">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <span class="badge mb-4">Local crew, honest quote</span>
          <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-6">An honest quote and the right deck for your home</h2>
          <p class="text-neutral-600 mb-5">Getting a deck built should be simple. We give you an honest, itemized quote up front, then help you pick the right material, wood or composite, that holds up in the Carolina weather and adds real value to your home.</p>
          <p class="text-neutral-600 mb-8">We are a local crew that builds decks and porches every week. We show up, we finish the job, and we do not disappear halfway through. Read the reviews below and see for yourself.</p>
          <ul class="space-y-4">{buildItems.map((item) => (<li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>))}</ul>
        </div>
        <div class="rounded-2xl overflow-hidden shadow-2xl"><img src={supportImage} alt="Wood deck with railing built by iFIXX in South Charlotte" class="w-full aspect-[4/3] object-cover" width="700" height="525" loading="lazy" decoding="async" /></div>
      </div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12">
        <span class="badge mb-4">Recent deck & outdoor living builds</span>
        <h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">Decks, porches, and outdoor spaces we've built</h2>
        <p class="text-neutral-600">A look at the kind of new decks, raised builds, screened porches, and outdoor living work we do for South Charlotte homes.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {galleryImages.map((image) => (<figure class="group overflow-hidden rounded-2xl bg-white shadow-sm border border-neutral-200"><img src={image.src} alt={image.alt} class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-300" width="520" height="390" loading="lazy" decoding="async" /></figure>))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="max-w-3xl mx-auto text-center mb-12"><span class="badge mb-4">Simple, honest process</span><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-4">From idea to finished deck</h2><p class="text-neutral-600">No pressure and no mystery pricing. Start with a free deck estimate and we will help you plan a deck that fits your home and budget.</p></div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">{processSteps.map((step, index) => (<div class="card p-6 text-center"><div class="w-14 h-14 mx-auto mb-4 rounded-full bg-primary-500 flex items-center justify-center font-heading font-bold text-neutral-900 text-xl">{index + 1}</div><h3 class="font-heading font-bold text-neutral-900 mb-2">{step.title}</h3><p class="text-sm text-neutral-600">{step.text}</p></div>))}</div>
    </div>
  </section>

  <section class="section section-alt">
    <div class="container">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-neutral-200"><h2 class="text-2xl font-heading font-bold text-neutral-900 mb-4">Who is iFIXX?</h2><img src="/images/ui/team.webp" alt="Jaime Aguilar, owner of iFIXX, with his team" class="w-full aspect-[16/9] object-cover rounded-xl mb-4" width="640" height="360" loading="lazy" decoding="async" /><p class="text-neutral-600 mb-4">Meet Jaime Aguilar, the owner. iFIXX is not a franchise or a call center: it is a local Charlotte family company, and the person responsible for your deck is the same person who answers your call.</p><ul class="space-y-3">{whoBullets.map((item) => (<li class="flex items-start gap-3"><span class="w-6 h-6 rounded-full bg-primary-500 flex items-center justify-center flex-shrink-0 mt-0.5 text-neutral-900 text-sm font-bold">✓</span><span class="text-neutral-700">{item}</span></li>))}</ul></div>
        <div class="bg-neutral-900 rounded-2xl p-8 text-white shadow-xl"><h2 class="text-2xl font-heading font-bold mb-4">South Charlotte service areas</h2><div class="flex flex-wrap gap-2">{serviceAreas.map((area) => (<span class="px-3 py-2 rounded-full bg-white/10 text-sm">{area}</span>))}</div><p class="text-neutral-300 mt-5">If you are nearby but not listed, send the request anyway and we will confirm availability.</p></div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container"><div class="max-w-3xl mx-auto"><h2 class="text-2xl lg:text-3xl font-heading font-bold text-neutral-900 mb-8 text-center">New Deck FAQs</h2><div class="space-y-4">{faqs.map((faq, index) => (<details class="group bg-white rounded-xl shadow-sm" open={index === 0}><summary class="flex items-center justify-between cursor-pointer list-none p-6"><span class="font-semibold text-neutral-900 pr-4">{faq.q}</span><span class="text-primary-600 group-open:rotate-180 transition-transform">⌄</span></summary><div class="px-6 pb-6"><p class="text-neutral-600 leading-relaxed">{faq.a}</p></div></details>))}</div></div></div>
  </section>

  <GoogleReviews title="What Charlotte Homeowners Say" />
  <CTASection headline="Ready to plan your new deck?" subtext="Request a free deck estimate for a new deck, rebuild, addition, screened porch, or outdoor living space in South Charlotte." />

  <script is:inline>
    document.addEventListener('click', (event) => {
      const cta = event.target.closest('.landing-primary-cta');
      const phone = event.target.closest('.landing-phone-cta');
      if (!cta && !phone) return;
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: cta ? 'landing_cta_click' : 'phone_click', lead_type: 'deck_build', campaign_test: 'ifixx_south_charlotte_service_test_2026_07', form_location: window.location.pathname });
    });
  </script>
</BaseLayout>
